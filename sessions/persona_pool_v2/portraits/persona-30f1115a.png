tination\":\"/documentation/serverless/pricing\"},{\"source\":\"/documentation/deployment/understand-runners\",\"destination\":\"/documentation/deployment/runners\"},{\"source\":\"/serverless/tutorials/text-to-image-model\",\"destination\":\"/examples/image-generation/deploy-text-to-image-model\"},{\"source\":\"/serverless/tutorials/text-to-music-model\",\"destination\":\"/examples/audio-speech/deploy-text-to-music-model\"},{\"source\":\"/serverless/tutorials/text-to-speech-model\",\"destination\":\"/examples/audio-speech/deploy-text-to-speech-model\"},{\"source\":\"/serverless/tutorials/text-to-video-model\",\"destination\":\"/examples/video-generation/deploy-text-to-video-model\"},{\"source\":\"/serverless/tutorials/working-with-containers\",\"destination\":\"/examples/deploy-models-with-custom-containers\"},{\"source\":\"/serverless/rest/runners\",\"destination\":\"/api-reference/cli/runners\"},{\"source\":\"/serverless/rest/logs\",\"destination\":\"/documentation/serverless/observability/monitor-performance\"},{\"source\":\"/compute/api\",\"destination\":\"/documentation/compute/quickstart\"},{\"source\":\"/clients\",\"destination\":\"/documentation/model-apis/inference/client-setup\"},{\"source\":\"/clients/javascript\",\"destination\":\"/documentation/model-apis/inference/client-setup\"},{\"source\":\"/clients/python\",\"destination\":\"/documentation/model-apis/inference/client-setup\"},{\"source\":\"/clients/swift\",\"destination\":\"/documentation/model-apis/inference/client-setup\"},{\"source\":\"/clients/java\",\"destination\":\"/documentation/model-apis/inference/client-setup\"},{\"source\":\"/clients/kotlin\",\"destination\":\"/documentation/model-apis/inference/client-setup\"},{\"source\":\"/clients/dart\",\"destination\":\"/documentation/model-apis/inference/client-setup\"},{\"source\":\"/model-endpoints\",\"destination\":\"/documentation/model-apis/inference/index\"},{\"source\":\"/model-endpoints/queue\",\"destination\":\"/documentation/model-apis/inference/queue\"},{\"source\":\"/model-endpoints/webhooks\",\"destination\":\"/documentation/model-apis/inference/webhooks\"},{\"source\":\"/model-endpoints/server-side\",\"destination\":\"/documentation/model-apis/inference/server-side\"},{\"source\":\"/model-endpoints/synchronous-requests\",\"destination\":\"/documentation/model-apis/inference/synchronous\"},{\"source\":\"/model-endpoints/websockets\",\"destination\":\"/documentation/model-apis/inference/websockets\"},{\"source\":\"/model-endpoints/workflows\",\"destination\":\"/documentation/model-apis/workflows\"},{\"source\":\"/examples/serverless/deploy-wan-lora-training\",\"destination\":\"/examples/image-generation/deploy-wan-lora-training\"},{\"source\":\"/serverless/development/app-files\",\"destination\":\"/documentation/development/app-files\"},{\"source\":\"/compute/_api\",\"destination\":\"/documentation/compute/_api\"}],\"contextual\":{\"options\":[\"copy\",\"view\",\"chatgpt\",\"claude\",\"perplexity\",\"mcp\",\"cursor\",\"vscode\"],\"display\":\"header\"}},\"docsNavWithMetadata\":{\"global\":{\"anchors\":[{\"anchor\":\"Status\",\"icon\":\"signal\",\"href\":\"https://status.fal.ai/\"},{\"anchor\":\"Community\",\"icon\":\"discord\",\"href\":\"https://discord.gg/fal-ai\"},{\"anchor\":\"Blog\",\"icon\":\"newspaper\",\"href\":\"https://blog.fal.ai/\"}]},\"tabs\":[{\"tab\":\"Documentation\",\"icon\":\"https://mintlify.s3.us-west-1.amazonaws.com/fal-d8505a2e/images/icons/docs.svg\",\"pages\":[{\"title\":\"Documentation\",\"sidebarTitle\":\"Overview\",\"description\":\"Learn how to build and deploy AI applications with fal\",\"og:title\":\"Build with fal\",\"layout\":\"wide\",\"href\":\"/documentation/index\",\"hidden\":false},{\"title\":\"Why fal?\",\"sidebarTitle\":\"Why fal?\",\"description\":\"Industry-leading inference speed for generative AI, trusted by top AI applications\",\"href\":\"/documentation/why-fal\",\"hidden\":false},{\"title\":\"Quick Start\",\"sidebarTitle\":\"Quick Start\",\"description\":\"Get started with fal in minutes\",\"href\":\"/documentation/quickstart\",\"hidden\":false},{\"group\":\"Setting Up\",\"icon\":\"/images/icons/gear.svg\",\"pages\":[{\"title\":\"Accounts and Identity\",\"description\":\"Set up your fal account, choose between personal and team workspaces, and understand how identity works on the platform.\",\"href\":\"/documentation/setting-up/accounts-and-identity\",\"hidden\":false},{\"title\":\"Teams\",\"description\":\"Create shared workspaces with their own API keys, deployments, and billing. Manage members, roles, and understand how request attribution works.\",\"href\":\"/documentation/setting-up/teams\",\"hidden\":false},{\"title\":\"Get Your API Key\",\"sidebarTitle\":\"Get Your API Key\",\"description\":\"Create an API key to authenticate your requests to fal\",\"href\":\"/documentation/setting-up/authentication/index\",\"hidden\":false},{\"title\":\"AI Tools\",\"description\":\"Use AI coding assistants to build with fal faster\",\"sidebarTitle\":\"AI Tools\",\"href\":\"/documentation/setting-up/mcp\",\"hidden\":false},{\"title\":\"Libraries, APIs, and Community\",\"sidebarTitle\":\"Resources\",\"description\":\"Client libraries, open-source packages, API references, and community links for building with fal.\",\"href\":\"/documentation/setting-up/resources\",\"hidden\":false}]},{\"group\":\"Model APIs\",\"icon\":\"/images/icons/ar-cube-1.svg\",\"pages\":[{\"title\":\"Model APIs\",\"sidebarTitle\":\"Overview\",\"description\":\"Access 1,000+ production-ready AI models through simple API calls\",\"href\":\"/documentation/model-apis/overview\",\"hidden\":false},{\"title\":\"Playground\",\"sidebarTitle\":\"Playground\",\"description\":\"Test any model with real inputs, see results, and copy working code.\",\"href\":\"/documentation/model-apis/playground\",\"hidden\":false},{\"group\":\"Inference Methods\",\"pages\":[{\"title\":\"Inference Methods\",\"sidebarTitle\":\"Overview\",\"description\":\"Learn the different ways to call models on fal\",\"href\":\"/documentation/model-apis/inference/index\",\"hidden\":false},{\"title\":\"Client Setup\",\"sidebarTitle\":\"Client Setup\",\"description\":\"Install and configure the fal client library\",\"href\":\"/documentation/model-apis/inference/client-setup\",\"hidden\":false},{\"title\":\"Proxy Setup\",\"sidebarTitle\":\"Proxy Setup\",\"description\":\"Keep your API key secure in client-side applications\",\"href\":\"/documentation/model-apis/inference/proxy-setup\",\"hidden\":false},{\"group\":\"Async\",\"pages\":[{\"title\":\"Asynchronous Inference\",\"sidebarTitle\":\"Overview\",\"description\":\"The recommended way to call models on fal\",\"href\":\"/documentation/model-apis/inference/queue\",\"hidden\":false},{\"title\":\"Webhooks\",\"description\":\"Webhooks work in tandem with the queue system explained above, it is another way to interact with our queue. By providing us a webhook endpoint you get notified when the request is done as opposed to polling it.\",\"sidebarTitle\":\"Webhooks\",\"href\":\"/documentation/model-apis/inference/webhooks\",\"hidden\":false},{\"title\":\"Reliability\",\"description\":\"How fal ensures high reliability for your API requests through queueing, automatic retries, and model fallbacks.\",\"sidebarTitle\":\"Reliability\",\"href\":\"/documentation/model-apis/inference/reliability\",\"hidden\":false}]},{\"title\":\"Synchronous Inference\",\"sidebarTitle\":\"Synchronous\",\"description\":\"A convenience wrapper for simple blocking calls\",\"href\":\"/documentation/model-apis/inference/synchronous\",\"hidden\":false},{\"title\":\"Streaming Inference\",\"sidebarTitle\":\"Streaming\",\"description\":\"Get progressive output as it's generated\",\"href\":\"/documentation/model-apis/inference/streaming\",\"hidden\":false},{\"title\":\"Real-Time Inference\",\"sidebarTitle\":\"Real-Time\",\"description\":\"WebSocket-based inference for ultra-low latency applications\",\"href\":\"/documentation/model-apis/inference/real-time\",\"hidden\":false}]},{\"title\":\"Platform Headers\",\"sidebarTitle\":\"Platform Headers\",\"description\":\"HTTP headers that control request behavior across all inference methods on fal.\",\"href\":\"/documentation/model-apis/common-parameters\",\"hidden\":false},{\"title\":\"Common Model Arguments\",\"sidebarTitle\":\"Model Arguments\",\"description\":\"Input parameters like seed, image_size, and safety checker that appear across many models on fal.\",\"href\":\"/documentation/model-apis/model-arguments\",\"hidden\":false},{\"title\":\"fal CDN\",\"sidebarTitle\":\"fal CDN\",\"description\":\"Upload files to fal's CDN to use as inputs when calling models.\",\"href\":\"/documentation/model-apis/fal-cdn\",\"hidden\":false},{\"title\":\"Data Retention \u0026 Storage\",\"sidebarTitle\":\"Data Retention\",\"description\":\"How fal stores your request data and generated media, and how to control retention.\",\"href\":\"/documentation/model-apis/media-expiration\",\"hidden\":false},{\"group\":\"Errors\",\"pages\":[{\"title\":\"Model Errors\",\"sidebarTitle\":\"Model Errors\",\"description\":\"Validation and content errors returned by models when inputs don't meet requirements.\",\"href\":\"/documentation/model-apis/errors\",\"hidden\":false},{\"title\":\"Request Error Types\",\"sidebarTitle\":\"Request Errors\",\"description\":\"Infrastructure-level error types for timeouts, runner failures, and connection errors.\",\"href\":\"/documentation/model-apis/request-errors\",\"hidden\":false}]},{\"title\":\"Concurrency Limits\",\"sidebarTitle\":\"Concurrency Limits\",\"description\":\"Understand and manage how many requests you can run simultaneously on fal.\",\"href\":\"/documentation/model-apis/concurrency-limits\",\"hidden\":false},{\"title\":\"Workflow Endpoints\",\"description\":\"Workflows are a way to chain multiple models together to create a more complex pipeline. This allows you to create a single endpoint that can take an input and pass it through multiple models in sequence. This is useful for creating more complex models that require multiple steps, or for creating a single endpoint that can handle multiple tasks.\",\"sidebarTitle\":\"Workflows\",\"href\":\"/documentation/model-apis/workflows\",\"hidden\":false},{\"title\":\"Sandbox\",\"description\":\"Sandbox is your creative playground for testing and comparing the latest AI models across all popular media generation operations. Compare models side-by-side, estimate costs before running, and share your creations.\",\"sidebarTitle\":\"Sandbox\",\"href\":\"/documentation/model-apis/sandbox\",\"hidden\":false},{\"title\":\"Pricing\",\"description\":\"How billing works for fal Model APIs.\",\"href\":\"/documentation/model-apis/pricing\",\"hidden\":false},{\"title\":\"FAQ\",\"sidebarTitle\":\"FAQ\",\"description\":null,\"href\":\"/documentation/model-apis/faq\",\"hidden\":false}]},{\"group\":\"Serverless\",\"icon\":\"/images/icons/rocket.svg\",\"pages\":[{\"title\":\"Introduction to Serverless\",\"sidebarTitle\":\"Introduction\",\"description\":\"Deploy custom AI models on GPU infrastructure that autoscales from zero to thousands of machines.\",\"href\":\"/documentation/serverless/index\",\"hidden\":false},{\"group\":\"Development\",\"pages\":[{\"group\":\"Getting Started\",\"pages\":[{\"title\":\"Installation \u0026 Setup\",\"description\":\"Complete setup guide for the fal CLI and development environment. This guide covers all platforms and authentication methods.\",\"href\":\"/documentation/development/getting-started/installation\",\"hidden\":false},{\"title\":\"Quick Start - Hello World\",\"sidebarTitle\":\"Quick Start\",\"description\":\"Deploy your first fal app in under 2 minutes. Learn the basics with a simple Hello World example.\",\"href\":\"/documentation/development/getting-started/quick-start\",\"hidden\":false},{\"title\":\"Deploy Your First Image Generator\",\"sidebarTitle\":\"Deploy Your First Image Generator\",\"description\":\"Deploy a text-to-image AI model in under 5 minutes. This tutorial walks you through creating your own image generation API using Stable Diffusion XL.\",\"href\":\"/documentation/development/getting-started/deploy-your-first-image-generator\",\"hidden\":false}]},{\"title\":\"App Lifecycle\",\"sidebarTitle\":\"App Lifecycle\",\"description\":\"The complete lifecycle of a fal app, from writing code to runner shutdown.\",\"href\":\"/documentation/development/app-lifecycle\",\"hidden\":false},{\"group\":\"Migrating to fal\",\"pages\":[{\"title\":\"Migrating to fal\",\"sidebarTitle\":\"Overview\",\"description\":\"Bring your existing models and infrastructure to fal with minimal code changes.\",\"href\":\"/documentation/development/migrating-to-fal\",\"hidden\":false},{\"title\":\"Migrate an External Docker Server\",\"description\":\"Deploy an existing Docker-based server (ComfyUI, custom APIs) to fal's serverless platform.\",\"href\":\"/documentation/development/migrate-external-docker-server\",\"hidden\":false},{\"title\":\"Migrate from Replicate\",\"sidebarTitle\":\"Migrate from Replicate\",\"description\":\"A guide for migrating your Replicate Cog models to fal.\",\"href\":\"/documentation/development/migrate-from-replicate\",\"hidden\":false},{\"title\":\"Migrate from Modal\",\"sidebarTitle\":\"Migrate from Modal\",\"description\":\"A guide for migrating your Modal applications to fal.\",\"href\":\"/documentation/development/migrate-from-modal\",\"hidden\":false},{\"title\":\"Migrate from RunPod\",\"sidebarTitle\":\"Migrate from RunPod\",\"description\":\"A guide for migrating your RunPod Serverless workers to fal.\",\"href\":\"/documentation/development/migrate-from-runpod\",\"hidden\":false}]},{\"group\":\"Defining Your Environment\",\"pages\":[{\"title\":\"Environment and Runtime\",\"sidebarTitle\":\"Overview\",\"description\":\"Choose how to define the environment your fal app runs in.\",\"href\":\"/documentation/development/container-setup\",\"hidden\":false},{\"group\":\"Using a Dockerfile\",\"pages\":[{\"title\":\"Use a Custom Container Image\",\"description\":\"Bring your own Dockerfile to fal for full control over system packages, CUDA versions, and base images.\",\"href\":\"/documentation/development/use-custom-container-image\",\"hidden\":false},{\"title\":\"Docker Templates and Best Practices\",\"sidebarTitle\":\"Docker Templates\",\"description\":\"Production-ready Dockerfile templates and optimization tips for fal Serverless.\",\"href\":\"/documentation/development/docker-templates\",\"hidden\":false},{\"title\":\"Private Docker Registries\",\"description\":\"How to authenticate with private registries like Docker Hub, Google Artifact Registry, and AWS ECR.\",\"href\":\"/documentation/development/private-registries\",\"hidden\":false}]},{\"group\":\"Using pip Requirements\",\"pages\":[{\"title\":\"fal Runtime\",\"sidebarTitle\":\"Overview\",\"description\":\"How to use fal's managed Python runtime to run your models.\",\"href\":\"/documentation/development/fal-runtime\",\"hidden\":false},{\"title\":\"Import Code\",\"description\":\"Bring local Python modules, files, and external repositories into your fal app's remote environment.\",\"href\":\"/documentation/development/import-code\",\"hidden\":false}]}]},{\"group\":\"Application Setup\",\"pages\":[{\"title\":\"Application Setup\",\"sidebarTitle\":\"Overview\",\"description\":\"Prepare your app's runtime environment: load models, download weights, and configure persistent storage.\",\"href\":\"/documentation/development/app-setup\",\"hidden\":false},{\"title\":\"Persistent Storage\",\"sidebarTitle\":\"Persistent Storage\",\"description\":\"Store model weights, datasets, and files on the shared /data volume that persists across runners and deployments.\",\"href\":\"/documentation/development/use-persistent-storage\",\"hidden\":false},{\"title\":\"Download Model Weights and Files\",\"description\":\"Download model weights, datasets, and external files to your runner using fal toolkit utilities and Hugging Face best practices.\",\"href\":\"/documentation/development/download-model-weights-and-files\",\"hidden\":false}]},{\"group\":\"Define your endpoints\",\"pages\":[{\"title\":\"Define Your Endpoints\",\"sidebarTitle\":\"Overview\",\"description\":\"How to define, structure, and configure the API endpoints your fal App exposes to callers.\",\"href\":\"/documentation/development/endpoints-overview\",\"hidden\":false},{\"title\":\"Handle Inputs and Outputs\",\"description\":\"Define input and output schemas for your fal App endpoints that render correctly in the Playground.\",\"href\":\"/documentation/development/handle-inputs-and-outputs\",\"hidden\":false},{\"title\":\"Working with Files\",\"sidebarTitle\":\"Working with Files\",\"description\":\"Download input files and return generated outputs from your fal App using the toolkit's file types and download utilities.\",\"href\":\"/documentation/development/working-with-files\",\"hidden\":false},{\"title\":\"Streaming Endpoints\",\"description\":\"Stream progressive results to clients using Server-Sent Events (SSE) for real-time feedback during long-running operations.\",\"href\":\"/documentation/development/streaming\",\"hidden\":false},{\"title\":\"Realtime Endpoints\",\"description\":\"Build low-latency, bidirectional WebSocket endpoints for interactive applications that require persistent connections and back-to-back requests.\",\"href\":\"/documentation/development/realtime\",\"hidden\":false},{\"title\":\"Test Models and Endpoints\",\"description\":\"Test your fal App endpoints programmatically using AppClient, which deploys an ephemeral instance and runs your tests against live infrastructure.\",\"href\":\"/documentation/development/test-models-and-endpoints\",\"hidden\":false},{\"title\":\"Add Health Check Endpoint\",\"description\":\"Add a health check endpoint to your fal app so the platform can detect and replace unhealthy runners.\",\"href\":\"/documentation/development/add-health-check-endpoint\",\"hidden\":false},{\"title\":\"Handle Request Cancellations\",\"sidebarTitle\":\"Cancellations\",\"description\":\"Handle in-flight request cancellations to free GPU resources when callers cancel queued or processing requests.\",\"href\":\"/documentation/development/handle-cancellations\",\"hidden\":false}]},{\"title\":\"Calling Your Endpoints\",\"description\":\"How to call your deployed serverless endpoints using the fal client SDKs.\",\"href\":\"/documentation/development/calling-your-endpoints\",\"hidden\":false},{\"title\":\"Logging\",\"description\":\"Understand how logs are captured, scoped, and surfaced across runner logs, request logs, and the Playground.\",\"href\":\"/documentation/development/logging\",\"hidden\":false},{\"title\":\"Secrets\",\"description\":\"Store API keys, credentials, and other sensitive configuration securely, accessible to your fal App at runtime.\",\"href\":\"/documentation/development/manage-secrets-securely\",\"hidden\":false},{\"title\":\"Environment Variables\",\"sidebarTitle\":\"Environment Variables\",\"description\":\"Built-in environment variables that fal injects into every runner, covering authentication, app identity, lifecycle state, and storage.\",\"href\":\"/documentation/development/environment-variables\",\"hidden\":false},{\"title\":\"Request Headers\",\"sidebarTitle\":\"Request Headers\",\"description\":\"Access request headers in your fal App for logging, tracing, and per-request logic.\",\"href\":\"/documentation/development/request-headers\",\"hidden\":false},{\"group\":\"Advanced\",\"pages\":[{\"group\":\"Multi-GPU Workloads\",\"pages\":[{\"title\":\"Overview\",\"sidebarTitle\":\"Overview\",\"description\":\"Learn how to leverage multiple GPUs for faster inference and training with fal.distributed\",\"href\":\"/documentation/serverless/distributed/overview\",\"hidden\":false},{\"title\":\"Event Streaming\",\"description\":\"Learn how to stream real-time results during distributed inference and training\",\"href\":\"/documentation/serverless/distributed/streaming\",\"hidden\":false},{\"title\":\"API Reference\",\"description\":\"Essential API reference for fal.distributed: the key methods you need to build multi-GPU applications\",\"href\":\"/documentation/serverless/distributed/api-reference\",\"hidden\":false}]},{\"title\":\"Optimize Routing Behavior\",\"description\":\"Use routing hints to direct requests to runners that already have the right model or state loaded in memory.\",\"href\":\"/documentation/development/advanced/optimize-routing-behavior\",\"hidden\":false},{\"title\":\"Multi-App Routing\",\"sidebarTitle\":\"Multi-App Routing\",\"description\":\"Use a lightweight proxy app to route requests between multiple fal apps based on input characteristics.\",\"href\":\"/documentation/development/multi-app-routing\",\"hidden\":false},{\"title\":\"Use KV Store\",\"description\":\"KVStore is a simple key-value storage for sharing state across serverless runners with zero setup required.\",\"href\":\"/documentation/development/use-kv-store\",\"hidden\":false}]}]},{\"group\":\"Deployment\",\"pages\":[{\"title\":\"Deployment Overview\",\"sidebarTitle\":\"Overview\",\"description\":\"Ship your fal applications to production, manage revisions and environments, configure scaling, and choose the right machine type.\",\"href\":\"/documentation/deployment/overview\",\"hidden\":false},{\"group\":\"Runners and Requests\",\"pages\":[{\"title\":\"Understanding Requests\",\"sidebarTitle\":\"Understanding Requests\",\"description\":\"How requests flow through fal's infrastructure, from submission through queue, dispatch, processing, and retries.\",\"href\":\"/documentation/deployment/requests\",\"hidden\":false},{\"title\":\"Understanding Runners\",\"sidebarTitle\":\"Understanding Runners\",\"description\":\"What runners are, how they start, process requests, scale, and shut down.\",\"href\":\"/documentation/deployment/runners\",\"hidden\":false},{\"title\":\"Caching\",\"sidebarTitle\":\"Caching\",\"description\":\"How fal's multi-layer caching system reduces cold start times by caching Docker images, model weights, and compiled artifacts.\",\"href\":\"/documentation/deployment/caching\",\"hidden\":false}]},{\"title\":\"Deploy to Production\",\"description\":\"Deploy your fal App to production with persistent URLs, authentication, and automatic scaling.\",\"href\":\"/documentation/deployment/deploy-to-production\",\"hidden\":false},{\"group\":\"Scaling Your Application\",\"pages\":[{\"title\":\"Scaling Parameter Reference\",\"sidebarTitle\":\"Parameter Reference\",\"description\":\"All scaling parameters for controlling runners, cold starts, and costs.\",\"href\":\"/documentation/deployment/scale-your-application\",\"hidden\":false},{\"title\":\"Updating Your Configuration\",\"sidebarTitle\":\"Updating Configuration\",\"description\":\"How to set scaling parameters via code, CLI, or dashboard -- and how they behave across deploys.\",\"href\":\"/documentation/deployment/scaling-configuration\",\"hidden\":false}]},{\"title\":\"Machine Types\",\"description\":\"Available machine types, specifications, and guidance on choosing the right GPU for your workload.\",\"href\":\"/documentation/deployment/machine-types\",\"hidden\":false},{\"title\":\"Manage Deployments\",\"description\":\"Once your models are deployed to production, you need tools and strategies to manage them effectively. This guide covers listing deployments, monitoring application health, managing multiple versions, and safely removing models.\",\"href\":\"/documentation/deployment/manage-deployments\",\"hidden\":false},{\"title\":\"Rollbacks \u0026 Revisions\",\"sidebarTitle\":\"Rollbacks \u0026 Revisions\",\"description\":\"Manage app revisions, roll back to previous versions, and restart runners.\",\"href\":\"/documentation/deployment/rollbacks\",\"hidden\":false},{\"title\":\"Manage Environments\",\"description\":\"Organize your fal Serverless applications, secrets, and configurations across different stages of your development workflow using environments. Create isolated spaces for development, staging, and production deployments.\",\"href\":\"/documentation/deployment/manage-environments\",\"hidden\":false}]},{\"group\":\"Reliability\",\"pages\":[{\"title\":\"Retries and Error Handling\",\"sidebarTitle\":\"Retries and Error Handling\",\"description\":\"How fal retries failed requests, what each status code does to runners, and how to control behavior with response headers.\",\"href\":\"/documentation/serverless/reliability/retries\",\"hidden\":false},{\"title\":\"GPU Health\",\"sidebarTitle\":\"GPU Health\",\"description\":\"How fal monitors GPU health, detects failures, and gives you control over runner health through custom health checks.\",\"href\":\"/documentation/serverless/reliability/gpu-health\",\"hidden\":false}]},{\"group\":\"Observability\",\"pages\":[{\"title\":\"Observability Overview\",\"sidebarTitle\":\"Overview\",\"description\":\"Monitor your fal applications using the dashboard, CLI, and programmatic integrations.\",\"href\":\"/documentation/serverless/observability/monitor-performance\",\"hidden\":false},{\"title\":\"App Analytics\",\"sidebarTitle\":\"App Analytics\",\"description\":\"Monitor your application's performance with real-time metrics and detailed analytics.\",\"href\":\"/documentation/serverless/observability/app-analytics\",\"hidden\":false},{\"title\":\"Error Analytics\",\"sidebarTitle\":\"Error Analytics\",\"description\":\"Explore, filter, and debug request errors across your applications.\",\"href\":\"/documentation/serverless/observability/error-analytics\",\"hidden\":false},{\"title\":\"App Events\",\"sidebarTitle\":\"App Events\",\"description\":\"Track deployments, runner lifecycle, and config changes with a full audit trail.\",\"href\":\"/documentation/serverless/observability/app-events\",\"hidden\":false},{\"title\":\"Exporting Metrics\",\"sidebarTitle\":\"Exporting Metrics\",\"description\":\"Export Prometheus-compatible metrics to Grafana, Datadog, or any monitoring tool.\",\"href\":\"/documentation/serverless/observability/exporting-metrics\",\"hidden\":false},{\"title\":\"Log Drains\",\"sidebarTitle\":\"Log Drains\",\"description\":\"Forward your application logs to external services like Datadog, Splunk, or Elasticsearch.\",\"href\":\"/documentation/serverless/observability/log-drains\",\"hidden\":false},{\"title\":\"Slack Notifications\",\"sidebarTitle\":\"Slack Notifications\",\"description\":\"Receive real-time alerts in Slack when your apps fail to start.\",\"href\":\"/documentation/serverless/observability/slack-notifications\",\"hidden\":false}]},{\"title\":\"Publishing to the Marketplace\",\"sidebarTitle\":\"Marketplace\",\"description\":\"Make your serverless app available on the fal Marketplace so anyone can call it with their own API key.\",\"href\":\"/documentation/serverless/publishing-to-marketplace\",\"hidden\":false},{\"group\":\"Optimizations\",\"pages\":[{\"group\":\"Optimizing Cold Starts\",\"pages\":[{\"title\":\"Optimizing Cold Starts\",\"sidebarTitle\":\"Overview\",\"description\":\"Understanding cold starts and how to reduce them.\",\"href\":\"/documentation/serverless/optimizations/optimize-cold-starts\",\"hidden\":false},{\"title\":\"Adjust Scaling Parameters\",\"sidebarTitle\":\"Scaling Parameters\",\"description\":\"Reduce cold starts by keeping warm runners available.\",\"href\":\"/documentation/serverless/optimizations/cold-start-scaling\",\"hidden\":false},{\"title\":\"Optimize Container Images\",\"description\":\"Container optimization is key to achieving faster cold starts, reducing deployment sizes, and improving overall application performance. This guide covers Dockerfile optimization techniques, layer caching strategies, multi-stage builds, and build performance improvements to help you create efficient containers for your fal.ai applications.\",\"href\":\"/documentation/serverless/optimizations/optimize-container-images\",\"hidden\":false},{\"title\":\"Optimize Startup with Compiled Caches\",\"description\":\"Reduce cold-start time for compiled PyTorch models by sharing Inductor caches across workers.\",\"href\":\"/documentation/serverless/optimizations/optimize-startup-with-compiled-caches\",\"hidden\":false},{\"title\":\"FlashPack\",\"sidebarTitle\":\"FlashPack\",\"description\":\"High-throughput tensor loading for PyTorch -- load models at up to 25Gbps without GDS.\",\"href\":\"/documentation/serverless/optimizations/flashpack\",\"hidden\":false},{\"title\":\"Parallel File Loading\",\"sidebarTitle\":\"Parallel File Loading\",\"description\":\"Speed up model loading by pre-reading files in parallel from /data.\",\"href\":\"/documentation/serverless/optimizations/parallel-file-loading\",\"hidden\":false}]},{\"title\":\"Optimizing Costs\",\"description\":null,\"href\":\"/documentation/serverless/optimizations/optimizing-costs\",\"hidden\":false}]},{\"title\":\"Pricing\",\"description\":\"How billing works for fal Serverless.\",\"href\":\"/documentation/serverless/pricing\",\"hidden\":false},{\"title\":\"FAQ\",\"sidebarTitle\":\"FAQ\",\"description\":null,\"href\":\"/documentation/serverless/faq\",\"hidden\":false}]},{\"group\":\"Compute\",\"icon\":\"/images/icons/chip.svg\",\"pages\":[{\"title\":\"Introduction to Compute\",\"description\":\"Dedicated GPU instances for training, fine-tuning, and workloads that need sustained access to hardware.\",\"sidebarTitle\":\"Introduction\",\"href\":\"/documentation/compute/index\",\"hidden\":false},{\"title\":\"Quickstart with Compute\",\"sidebarTitle\":\"Quickstart\",\"description\":\"Get up and running with fal Compute in minutes. This guide will walk you through provisioning your first GPU instance and connecting to it.\",\"href\":\"/documentation/compute/quickstart\",\"hidden\":false},{\"title\":\"Pricing\",\"description\":\"How billing works for fal Compute.\",\"href\":\"/documentation/compute/pricing\",\"hidden\":false}]},{\"group\":\"Organizations\",\"icon\":\"/images/icons/group-3.svg\",\"pages\":[{\"title\":\"Organizations\",\"sidebarTitle\":\"Overview\",\"description\":\"Centralized management for teams, billing, and model access across your company.\",\"href\":\"/documentation/organizations/index\",\"hidden\":false},{\"title\":\"Managing Teams\",\"sidebarTitle\":\"Managing Teams\",\"description\":\"Control team lifecycle, member management, and organization-wide policies.\",\"href\":\"/documentation/organizations/managing-teams\",\"hidden\":false},{\"title\":\"Model Access Controls\",\"sidebarTitle\":\"Model Access Controls\",\"description\":\"Restrict which models your team members can access via the API and Playground.\",\"href\":\"/documentation/organizations/access-controls\",\"hidden\":false}]},{\"title\":\"Support\",\"description\":\"Support documentation for fal.ai AI APIs. Developer guide with examples, best practices, and implementation details.\",\"topic\":\"modelapis\",\"href\":\"/documentation/model-apis/support\",\"hidden\":false}]},{\"tab\":\"Examples\",\"icon\":\"https://mintlify.s3.us-west-1.amazonaws.com/fal-d8505a2e/images/icons/grid-9.svg\",\"pages\":[{\"title\":\"Examples\",\"description\":\"Step-by-step tutorials and code examples for building with fal\",\"sidebarTitle\":\"Overview\",\"href\":\"/examples/index\",\"hidden\":false},{\"group\":\"Model APIs\",\"pages\":[{\"title\":\"Generate Images from Text Tutorial\",\"description\":null,\"href\":\"/examples/image-generation/generate-images-from-text\",\"hidden\":false},{\"title\":\"Generate Videos from Image Tutorial\",\"description\":null,\"href\":\"/examples/video-generation/generate-videos-from-image\",\"hidden\":false},{\"title\":\"Convert Speech to Text Tutorial\",\"sidebarTitle\":\"Convert Speech to Text\",\"description\":null,\"href\":\"/examples/audio-speech/convert-speech-to-text\",\"hidden\":false},{\"title\":\"Use LLMs Tutorial\",\"description\":\"fal provides an easy-to-use API for generating text using Language Models (LLMs). You can use the `fal-ai/any-llm` endpoint to generate text based on a given prompt and model.\",\"sidebarTitle\":\"Use LLMs\",\"href\":\"/examples/integrations/use-llms\",\"hidden\":false},{\"title\":\"Fastest FLUX Endpoint\",\"description\":\"We believe fal has the fastest FLUX endpoint in the planet. If you can find a faster one, we guarantee to beat it within one week. 🤝\",\"sidebarTitle\":\"Fastest FLUX in the Planet\",\"href\":\"/examples/image-generation/fast-flux\",\"hidden\":false},{\"title\":\"Fastest SDXL Endpoint\",\"sidebarTitle\":\"Fastest SDXL in the Planet\",\"description\":\"We believe fal has the fastest SDXL endpoint in the planet. If you can find a faster one, we guarantee to beat it within one week. 🤝\",\"href\":\"/examples/image-generation/fast-sdxl\",\"hidden\":false},{\"title\":\"Custom Workflow UI Tutorial\",\"sidebarTitle\":\"Custom Workflow UI\",\"description\":null,\"href\":\"/examples/integrations/custom-workflow-ui\",\"hidden\":false},{\"title\":\"Using fal within an n8n workflow\",\"description\":\"This guide will demonstrate, step-by-step, how to use fal within an n8n workflow.\",\"href\":\"/examples/integrations/n8n\",\"hidden\":false},{\"title\":\"Add fal.ai to your Next.js app Integration\",\"sidebarTitle\":\"Next.js\",\"description\":null,\"href\":\"/examples/integrations/nextjs\",\"hidden\":false},{\"title\":\"Add fal.ai to your Next.js app Integration\",\"sidebarTitle\":\"Vercel\",\"description\":null,\"href\":\"/examples/integrations/vercel\",\"hidden\":false}]},{\"group\":\"Serverless\",\"pages\":[{\"title\":\"Deploy a Text-to-Image Model\",\"description\":null,\"href\":\"/examples/image-generation/deploy-text-to-image-model\",\"hidden\":false},{\"title\":\"Deploy a ComfyUI SDXL Turbo App\",\"description\":\"Build a serverless image generation API using ComfyUI and SDXL Turbo on fal.\",\"href\":\"/examples/image-generation/deploy-comfyui-server\",\"hidden\":false},{\"title\":\"Deploy WAN LoRA Training\",\"description\":\"Fine-tune WAN (text-to-video) with LoRA using your own short clips and images.\",\"href\":\"/examples/image-generation/deploy-wan-lora-training\",\"hidden\":false},{\"title\":\"Deploy a Text-to-Video Model\",\"description\":\"This example demonstrates how to build a sophisticated text-to-video generation service using Wan2.1, showcasing advanced techniques including custom safety checking with multiple AI models, prompt expansion using LLMs, video tensor processing, and comprehensive integration of multiple fal services within a single application.\",\"href\":\"/examples/video-generation/deploy-text-to-video-model\",\"hidden\":false},{\"title\":\"Deploy 3D Progressive Rendering\",\"description\":\"Build a real-time text-to-3D and image-to-3D application with live voxel streaming using SAM-3D Objects.\",\"href\":\"/examples/video-generation/deploy-3d-progressive-rendering\",\"hidden\":false},{\"title\":\"Deploy Real-time Video-to-Video Model\",\"description\":\"Run a real-time video-to-video pipeline that returns YOLO detections on your stream.\",\"href\":\"/examples/video-generation/deploy-realtime-video-to-video-model\",\"hidden\":false},{\"title\":\"Deploy Real-time World Model\",\"description\":\"Run a real-time world model demo powered by Matrix-Game.\",\"href\":\"/examples/video-generation/deploy-realtime-world-model\",\"hidden\":false},{\"title\":\"Deploy Multi-GPU Inference\",\"description\":\"Learn how to build a multi-GPU image generation service using data parallelism with Stable Diffusion XL, including real-time streaming and distributed worker coordination.\",\"href\":\"/examples/video-generation/deploy-multi-gpu-inference\",\"hidden\":false},{\"title\":\"Deploy a Text-to-Speech Model\",\"description\":\"This example demonstrates how to build a comprehensive text-to-speech service using Kokoro, showcasing CPU-efficient deployment, multi-language support, multiple endpoints with shared logic, and advanced audio processing techniques.\",\"href\":\"/examples/audio-speech/deploy-text-to-speech-model\",\"hidden\":false},{\"title\":\"Deploy a Text-to-Music Model\",\"description\":\"This example demonstrates how to build a sophisticated text-to-music generation service using DiffRhythm, showcasing advanced fal features including custom Docker images, repository cloning, file downloading, and complex audio processing workflows.\",\"href\":\"/examples/audio-speech/deploy-text-to-music-model\",\"hidden\":false},{\"title\":\"Deploy Models with Custom Containers\",\"description\":\"fal now supports running apps within custom Docker containers, providing greater flexibility and control over your environment.\",\"href\":\"/examples/deploy-models-with-custom-containers\",\"hidden\":false},{\"title\":\"Migrate from Replicate\",\"description\":\"This guide will help you transition from using [Replicate](https://replicate.com/)'s tools, specifically their [Cog](https://github.com/replicate/cog) tool, to fal's platform. Cog is a tool used to package machine learning models in Docker containers, which simplifies the deployment process.\",\"href\":\"/examples/integrations/migrate-from-replicate\",\"hidden\":false},{\"title\":\"Migrate an External Docker Server\",\"description\":\"Deploy an existing Docker-based server (ComfyUI, custom APIs) to fal's serverless platform.\",\"href\":\"/examples/integrations/migrate-external-docker-server\",\"hidden\":false},{\"title\":\"Migrate from Modal\",\"description\":\"A guide for migrating your Modal applications to fal.\",\"href\":\"/examples/integrations/migrate-from-modal\",\"hidden\":false},{\"title\":\"Migrate from RunPod\",\"description\":\"A guide for migrating your RunPod Serverless workers to fal.\",\"href\":\"/examples/integrations/migrate-from-runpod\",\"hidden\":false}]}]},{\"tab\":\"SDK Reference\",\"icon\":\"https://mintlify.s3.us-west-1.amazonaws.com/fal-d8505a2e/images/icons/code-brackets.svg\",\"pages\":[{\"title\":\"Reference\",\"description\":\"Complete API and SDK reference documentation for fal\",\"href\":\"/api-reference/index\",\"hidden\":false},{\"group\":\"Client Libraries\",\"pages\":[{\"title\":\"Client Libraries\",\"description\":\"Libraries for calling fal AI models from your applications\",\"sidebarTitle\":\"Client Libraries\",\"href\":\"/api-reference/client-libraries/index\",\"hidden\":false},{\"group\":\"Python\",\"pages\":[{\"title\":\"Python Client\",\"description\":\"API reference for fal-client Python package\",\"sidebarTitle\":\"Overview\",\"href\":\"/api-reference/client-libraries/python/index\",\"hidden\":false},{\"title\":\"fal_client\",\"sidebarTitle\":\"fal_client\",\"description\":\"API reference for fal_client\",\"href\":\"/api-reference/client-libraries/python/fal_client\",\"hidden\":false}]},{\"group\":\"JavaScript\",\"pages\":[{\"title\":\"JavaScript Client\",\"description\":\"API reference for @fal-ai/client\",\"sidebarTitle\":\"Overview\",\"href\":\"/api-reference/client-libraries/javascript/index\",\"hidden\":false},{\"title\":\"auth\",\"sidebarTitle\":\"auth\",\"description\":\"API reference for @fal-ai/client auth\",\"href\":\"/api-reference/client-libraries/javascript/auth\",\"hidden\":false},{\"title\":\"client\",\"sidebarTitle\":\"client\",\"description\":\"API reference for @fal-ai/client client\",\"href\":\"/api-reference/client-libraries/javascript/client\",\"hidden\":false},{\"title\":\"middleware\",\"sidebarTitle\":\"middleware\",\"description\":\"API reference for @fal-ai/client middleware\",\"href\":\"/api-reference/client-libraries/javascript/middleware\",\"hidden\":false},{\"title\":\"queue\",\"sidebarTitle\":\"queue\",\"description\":\"API reference for @fal-ai/client queue\",\"href\":\"/api-reference/client-libraries/javascript/queue\",\"hidden\":false},{\"title\":\"realtime\",\"sidebarTitle\":\"realtime\",\"description\":\"API reference for @fal-ai/client realtime\",\"href\":\"/api-reference/client-libraries/javascript/realtime\",\"hidden\":false},{\"title\":\"response\",\"sidebarTitle\":\"response\",\"description\":\"API reference for @fal-ai/client response\",\"href\":\"/api-reference/client-libraries/javascript/response\",\"hidden\":false},{\"title\":\"retry\",\"sidebarTitle\":\"retry\",\"description\":\"API reference for @fal-ai/client retry\",\"href\":\"/api-reference/client-libraries/javascript/retry\",\"hidden\":false},{\"title\":\"storage\",\"sidebarTitle\":\"storage\",\"description\":\"API reference for @fal-ai/client storage\",\"href\":\"/api-reference/client-libraries/javascript/storage\",\"hidden\":false},{\"title\":\"streaming\",\"sidebarTitle\":\"streaming\",\"description\":\"API reference for @fal-ai/client streaming\",\"href\":\"/api-reference/client-libraries/javascript/streaming\",\"hidden\":false},{\"title\":\"types.client\",\"sidebarTitle\":\"types.client\",\"description\":\"API reference for @fal-ai/client types.client\",\"href\":\"/api-reference/client-libraries/javascript/types.client\",\"hidden\":false},{\"title\":\"types.common\",\"sidebarTitle\":\"types.common\",\"description\":\"API reference for @fal-ai/client types.common\",\"href\":\"/api-reference/client-libraries/javascript/types.common\",\"hidden\":false},{\"title\":\"utils\",\"sidebarTitle\":\"utils\",\"description\":\"API reference for @fal-ai/client utils\",\"href\":\"/api-reference/client-libraries/javascript/utils\",\"hidden\":false}]},{\"title\":\"Swift Client\",\"description\":\"fal client library for iOS, macOS, tvOS, and watchOS\",\"sidebarTitle\":\"Swift\",\"href\":\"/api-reference/client-libraries/swift/index\",\"hidden\":false},{\"title\":\"Kotlin / Java Client\",\"description\":\"fal client library for Android and JVM applications\",\"sidebarTitle\":\"Kotlin / Java\",\"href\":\"/api-reference/client-libraries/kotlin/index\",\"hidden\":false},{\"title\":\"Dart Client\",\"description\":\"fal client library for Flutter applications\",\"sidebarTitle\":\"Dart\",\"href\":\"/api-reference/client-libraries/dart/index\",\"hidden\":false}]},{\"group\":\"CLI Reference\",\"pages\":[{\"title\":\"CLI Reference\",\"description\":\"Complete reference for the fal command-line interface\",\"href\":\"/api-reference/cli/index\",\"hidden\":false},{\"title\":\"Installation\",\"description\":null,\"href\":\"/api-reference/cli/installation\",\"hidden\":false},{\"title\":\"fal auth\",\"description\":null,\"href\":\"/api-reference/cli/auth\",\"hidden\":false},{\"group\":\"fal apps\",\"pages\":[{\"title\":\"fal apps list\",\"description\":null,\"href\":\"/api-reference/cli/apps/list\",\"hidden\":false},{\"title\":\"fal apps list-rev\",\"description\":null,\"href\":\"/api-reference/cli/apps/list-rev\",\"hidden\":false},{\"title\":\"fal apps set-rev\",\"description\":null,\"href\":\"/api-reference/cli/apps/set-rev\",\"hidden\":false},{\"title\":\"fal apps rollout\",\"description\":null,\"href\":\"/api-reference/cli/apps/rollout\",\"hidden\":false},{\"title\":\"fal apps scale\",\"description\":null,\"href\":\"/api-reference/cli/apps/scale\",\"hidden\":false},{\"title\":\"fal apps runners\",\"description\":null,\"href\":\"/api-reference/cli/apps/runners\",\"hidden\":false},{\"title\":\"fal apps delete\",\"description\":null,\"href\":\"/api-reference/cli/apps/delete\",\"hidden\":false},{\"title\":\"fal apps delete-rev\",\"description\":null,\"href\":\"/api-reference/cli/apps/delete-rev\",\"hidden\":false}]},{\"title\":\"fal deploy\",\"description\":null,\"href\":\"/api-reference/cli/deploy\",\"hidden\":false},{\"title\":\"fal environments\",\"description\":null,\"href\":\"/api-reference/cli/environments\",\"hidden\":false},{\"title\":\"fal files\",\"description\":null,\"href\":\"/api-reference/cli/files\",\"hidden\":false},{\"title\":\"fal run\",\"description\":null,\"href\":\"/api-reference/cli/run\",\"hidden\":false},{\"title\":\"fal queue\",\"description\":\"Manage application queues.\",\"href\":\"/api-reference/cli/queue\",\"hidden\":false},{\"title\":\"fal keys\",\"description\":null,\"href\":\"/api-reference/cli/keys\",\"hidden\":false},{\"title\":\"fal profile\",\"description\":null,\"href\":\"/api-reference/cli/profile\",\"hidden\":false},{\"title\":\"fal secrets\",\"description\":null,\"href\":\"/api-reference/cli/secrets\",\"hidden\":false},{\"title\":\"fal doctor\",\"description\":null,\"href\":\"/api-reference/cli/doctor\",\"hidden\":false},{\"title\":\"fal create\",\"description\":null,\"href\":\"/api-reference/cli/create\",\"hidden\":false},{\"title\":\"fal runners\",\"description\":null,\"href\":\"/api-reference/cli/runners\",\"hidden\":false},{\"title\":\"fal teams\",\"description\":null,\"href\":\"/api-reference/cli/teams\",\"hidden\":false},{\"title\":\"fal api\",\"description\":null,\"href\":\"/api-reference/cli/api\",\"hidden\":false}]},{\"group\":\"Python SDK\",\"pages\":[{\"title\":\"Python SDK\",\"description\":\"API reference for the fal Python package\",\"sidebarTitle\":\"Overview\",\"href\":\"/api-reference/python-sdk/fal-app-reference\",\"hidden\":false},{\"title\":\"SyncServerlessClient\",\"description\":\"Synchronous Python client for fal Serverless. Manage apps, runners, and deployments programmatically.\",\"href\":\"/api-reference/python-sdk/client\",\"hidden\":false},{\"title\":\"fal.api\",\"sidebarTitle\":\"fal.api\",\"description\":\"API reference for fal.api\",\"href\":\"/api-reference/python-sdk/api-reference\",\"hidden\":false},{\"title\":\"fal\",\"sidebarTitle\":\"fal\",\"description\":\"API reference for fal\",\"href\":\"/api-reference/python-sdk/fal\",\"hidden\":false},{\"title\":\"fal.distributed\",\"sidebarTitle\":\"fal.distributed\",\"description\":\"API reference for fal.distributed\",\"href\":\"/api-reference/python-sdk/fal-distributed\",\"hidden\":false},{\"title\":\"fal.exceptions\",\"sidebarTitle\":\"fal.exceptions\",\"description\":\"API reference for fal.exceptions\",\"href\":\"/api-reference/python-sdk/fal-exceptions\",\"hidden\":false},{\"title\":\"fal.toolkit\",\"sidebarTitle\":\"fal.toolkit\",\"description\":\"API reference for fal.toolkit\",\"href\":\"/api-reference/python-sdk/fal-toolkit\",\"hidden\":false},{\"title\":\"fal.toolkit.image.nsfw_filter\",\"sidebarTitle\":\"fal.toolkit.image.nsfw_filter\",\"description\":\"API reference for fal.toolkit.image.nsfw_filter\",\"href\":\"/api-reference/python-sdk/fal-toolkit-image-nsfw-filter\",\"hidden\":false}]}]},{\"tab\":\"Platform API\",\"icon\":\"https://mintlify.s3.us-west-1.amazonaws.com/fal-d8505a2e/images/icons/layers-three.svg\",\"pages\":[{\"title\":\"Introduction to Platform APIs\",\"description\":\"Platform APIs provide programmatic access to platform resources including model metadata, pricing information, usage tracking, and analytics.\",\"sidebarTitle\":\"Introduction\",\"href\":\"/api-reference/platform-apis/index\",\"hidden\":false},{\"title\":\"Authentication\",\"description\":\"Platform APIs require API keys for secure access to your user or team's data.\",\"href\":\"/api-reference/platform-apis/authentication\",\"hidden\":false},{\"title\":\"OpenAPI Schema\",\"description\":\"The fal Platform API is documented using the OpenAPI 3.1 specification format.\",\"href\":\"/api-reference/platform-apis/openapi-schema\",\"hidden\":false},{\"group\":\"API Endpoints\",\"pages\":[{\"title\":\"Platform Metadata\",\"openapi\":\"GET /meta\",\"description\":\"\\nReturns platform metadata including webhook IP ranges for allowlisting.\\n\\nIf your infrastructure requires allowlisting IP addresses for incoming webhook\\nrequests, this endpoint provides the current list of IP ranges used by fal.ai\\nwebhooks in CIDR notation.\\n    \",\"href\":\"/api-reference/platform-apis/meta\",\"hidden\":false},{\"title\":\"Platform APIs for Models\",\"description\":\"Programmatic access to model metadata, pricing, usage tracking, and analytics\",\"href\":\"/api-reference/platform-apis/for-models\",\"hidden\":false},{\"title\":\"Model search\",\"description\":\"$2b\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /models\",\"href\":\"/platform-apis/v1/models\",\"autogeneratedByOpenApi\":true},{\"title\":\"Pricing\",\"description\":\"\\nReturns unit pricing for requested endpoint IDs. Most models use\\n**output-based** pricing (e.g., per image/video with proportional\\nadjustments for resolution/length). Some models use **GPU-based** pricing\\ndepending on architecture. Values are expressed per model's billing unit\\nin a given currency.\\n\\n**Authentication:** Required. Users must provide a valid API key. \\nCustom pricing or discounts may be applied based on account status.\\n\\n**Common Use Cases:**\\n- Display pricing in user interfaces\\n- Compare pricing across different models\\n- Build cost estimation tools\\n- Check current billing rates\\n\\nSee [fal.ai pricing](https://fal.ai/pricing) for more details.\\n    \",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /models/pricing\",\"href\":\"/platform-apis/v1/models/pricing\",\"autogeneratedByOpenApi\":true},{\"title\":\"Estimate cost\",\"description\":\"\\nComputes cost estimates using one of two methods:\\n\\n**1. Historical API Price** (`historical_api_price`):\\n- Based on historical pricing per API call from past usage patterns\\n- Takes `call_quantity` (number of API calls) per endpoint\\n- Useful for estimating based on actual historical usage patterns\\n- Example: \\\"How much will 100 calls to flux/dev cost?\\\"\\n\\n**2. Unit Price** (`unit_price`):\\n- Based on unit price × expected billing units from pricing service\\n- Takes `unit_quantity` (number of billing units like images/videos) per endpoint\\n- Useful when you know the expected output quantity\\n- Example: \\\"How much will 50 images from flux/dev cost?\\\"\\n\\n**Authentication:** Required. Users must provide a valid API key.\\nCustom pricing or discounts may be applied based on account status.\\n\\n**Common Use Cases:**\\n- Pre-calculate costs for batch operations\\n- Display cost estimates in user interfaces\\n- Budget planning and cost optimization\\n\\nSee [fal.ai pricing](https://fal.ai/pricing) for more details.\\n    \",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json post /models/pricing/estimate\",\"href\":\"/platform-apis/v1/models/pricing/estimate\",\"autogeneratedByOpenApi\":true},{\"title\":\"Usage\",\"description\":\"\\nReturns paginated usage records for your workspace with filters for endpoint,\\nuser, date range, and auth method. Each item includes the billed unit\\nquantity and unit price used to compute cost.\\n\\n**Key Features:**\\n- Usage data for all endpoints or filtered by specific endpoint(s)\\n- Flexible date range filtering\\n- User-specific usage tracking\\n- Detailed usage line items with unit quantity and price\\n- Paginated results for large datasets\\n\\n**Common Use Cases:**\\n- Generate usage reports for all endpoints or specific models\\n- Track usage patterns\\n- Monitor endpoint usage across different auth methods\\n- Build usage dashboards and visualizations\\n\\nSee [fal.ai docs](https://docs.fal.ai/model-apis/faq) for more details.\\n    \",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /models/usage\",\"href\":\"/platform-apis/v1/models/usage\",\"autogeneratedByOpenApi\":true},{\"title\":\"Analytics\",\"description\":\"$2c\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /models/analytics\",\"href\":\"/platform-apis/v1/models/analytics\",\"autogeneratedByOpenApi\":true},{\"title\":\"List requests by endpoint\",\"description\":\"Lists requests for a specific endpoint.\\n\\n**Authentication:** Requires API key (user or enterprise).\\n\\n**Filters:**\\n- Time range via start / end\\n- Status (success, error, user_error)\\n- Request ID\\n- Pagination via cursor/limit (limit defaults to 50, max 100)\\n\\n**Sorting:**\\n- By end time (default) or duration\\n\\n**Expansions:**\\n- Include payloads by adding expand=payloads\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /models/requests/by-endpoint\",\"href\":\"/platform-apis/v1/models/requests/by-endpoint\",\"autogeneratedByOpenApi\":true},{\"title\":\"Delete request payloads\",\"description\":\"Deletes the IO payloads and associated CDN output files for a specific request.\\n\\n**Important:**\\n- Only **output** CDN files are deleted (input files may be used by other requests)\\n- This action is irreversible\\n- Requires authentication with an admin API key\\n\\n**What gets deleted:**\\n- Request input/output payload data\\n- CDN-hosted output files (images, videos, etc.)\\n\\n**What is NOT deleted:**\\n- Input CDN files (may be referenced by other requests)\\n\\n**Response:**\\n- Returns deletion status for each CDN file\\n- Each result includes the file link and any error that occurred\\n\\n**Idempotency:**\\n- Optional Idempotency-Key header prevents duplicate deletions on retries\\n- Responses cached for 10 minutes per unique key\\n\\nSee [fal.ai docs](https://docs.fal.ai/model-apis/payloads) for more details about request payloads.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json delete /models/requests/{request_id}/payloads\",\"href\":\"/platform-apis/v1/models/requests/payloads\",\"autogeneratedByOpenApi\":true},{\"title\":\"Platform APIs for Workflows\",\"description\":\"Programmatic access to workflow metadata, listing, and details\",\"href\":\"/api-reference/platform-apis/for-workflows\",\"hidden\":false},{\"title\":\"List user workflows\",\"description\":\"\\nList workflows for the authenticated user with optional search and filtering.\\n\\n**Features:**\\n- Paginated results with cursor-based pagination\\n- Search by workflow name or title\\n- Filter by model endpoints used in the workflow\\n\\n**Authentication:** Required. Returns only workflows owned by the authenticated user.\\n\\n**Common Use Cases:**\\n- Display user's workflow library\\n- Search for specific workflows\\n- Find workflows using particular models\\n    \",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /workflows\",\"href\":\"/platform-apis/v1/workflows\",\"autogeneratedByOpenApi\":true},{\"title\":\"Get workflow details\",\"description\":\"\\nGet detailed information about a specific workflow, including its full contents/definition.\\n\\n**Authentication:** Required.\\n\\n**Common Use Cases:**\\n- Load a workflow for editing\\n- View workflow configuration\\n- Export workflow definition\\n    \",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /workflows/{username}/{workflow_name}\",\"href\":\"/platform-apis/v1/workflows/{username}/{workflow_name}\",\"autogeneratedByOpenApi\":true},{\"title\":\"Platform APIs for Serverless\",\"description\":\"Programmatic access to serverless apps metadata and analytics\",\"href\":\"/api-reference/platform-apis/for-serverless\",\"hidden\":false},{\"title\":\"Queue Size\",\"description\":\"Retrieves the current queue size for a specific application.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /serverless/apps/{owner}/{name}/queue\",\"href\":\"/platform-apis/v1/serverless/apps/queue\",\"autogeneratedByOpenApi\":true},{\"title\":\"Flush Application Queue\",\"description\":\"Flushes all pending requests from an application's queue.\\n\\n**Authentication:** Required via API key\\n\\n**Idempotency:**\\n- Optional `Idempotency-Key` header prevents duplicate flushes on retries\\n- Responses cached for 10 minutes per unique key\\n\\n**Use Cases:**\\n- Clear stuck or outdated requests from the queue\\n- Reset queue state during development or testing\\n- Cancel all pending requests for an application\\n\\n**Important:**\\n- This operation is irreversible\\n- All pending requests in the queue will be cancelled\\n- Requests already being processed will not be affected\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json delete /serverless/apps/{owner}/{name}/queue\",\"href\":\"/platform-apis/v1/serverless/apps/{owner}/{name}/queue\",\"autogeneratedByOpenApi\":true},{\"title\":\"Metrics\",\"description\":\"$2d\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /serverless/metrics\",\"href\":\"/platform-apis/v1/serverless/metrics\",\"autogeneratedByOpenApi\":true},{\"title\":\"List requests by endpoint\",\"description\":\"Lists requests for endpoints accessible to the authenticated user.\\n\\n**Authentication:** Requires API key.\\n\\n**Filters:**\\n- Time range via start / end\\n- Status (success, error, user_error)\\n- Request ID\\n- Pagination via cursor/limit (limit defaults to 50, max 100)\\n\\n**Sorting:**\\n- By end time (default) or duration\\n\\n**Expansions:**\\n- Include payloads by adding expand=payloads\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /serverless/requests/by-endpoint\",\"href\":\"/platform-apis/v1/serverless/requests/by-endpoint\",\"autogeneratedByOpenApi\":true},{\"title\":\"List files (root)\",\"description\":\"Lists files and folders in the root of your project storage.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /serverless/files/list\",\"href\":\"/platform-apis/v1/serverless/files/list\",\"autogeneratedByOpenApi\":true},{\"title\":\"List files (directory)\",\"description\":\"Lists files and folders within the specified directory path.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /serverless/files/list/{dir}\",\"href\":\"/platform-apis/v1/serverless/files/list/{dir}\",\"autogeneratedByOpenApi\":true},{\"title\":\"Download file\",\"description\":\"Downloads a file by its path. Proxies the underlying storage response.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /serverless/files/file/{file}\",\"href\":\"/platform-apis/v1/serverless/files/file/{file}\",\"autogeneratedByOpenApi\":true},{\"title\":\"Upload file from URL\",\"description\":\"Creates a new file at the target path by downloading it from the provided URL.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json post /serverless/files/file/url/{file}\",\"href\":\"/platform-apis/v1/serverless/files/file/url/{file}\",\"autogeneratedByOpenApi\":true},{\"title\":\"Upload local file (multipart/form-data)\",\"description\":\"Uploads a local file using multipart/form-data. The file field name must be `file_upload`.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json post /serverless/files/file/local/{target_path}\",\"href\":\"/platform-apis/v1/serverless/files/file/local/{target_path}\",\"autogeneratedByOpenApi\":true},{\"title\":\"Logs history (paginated)\",\"description\":\"Returns paginated historical logs that match the provided filters.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json post /serverless/logs/history\",\"href\":\"/platform-apis/v1/serverless/logs/history\",\"autogeneratedByOpenApi\":true},{\"title\":\"Logs stream (SSE)\",\"description\":\"Streams live logs that match the provided filters using Server-Sent Events.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json post /serverless/logs/stream\",\"href\":\"/platform-apis/v1/serverless/logs/stream\",\"autogeneratedByOpenApi\":true},{\"title\":\"Platform APIs for Compute\",\"description\":\"Programmatic access to compute instance management, lifecycle control, and monitoring\",\"href\":\"/api-reference/platform-apis/for-compute\",\"hidden\":false},{\"title\":\"List Compute Instances\",\"description\":\"Returns a list of all compute instances belonging to the authenticated user's workspace.\\n\\n**Requirements:**\\n- Requires compute permissions (extra_permissions.compute = true)\\n- Authentication required via admin API key\\n\\n**Key Features:**\\n- View all instances regardless of status\\n- Includes instance configuration, region, and current status\\n- Paginated results for large instance lists\\n\\n**Common Use Cases:**\\n- Monitor all active compute resources\\n- Check instance status and availability\\n- Audit compute resource usage\\n- Build compute management dashboards\\n\\nSee [fal.ai docs](https://docs.fal.ai/compute) for more details.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /compute/instances\",\"href\":\"/platform-apis/v1/compute/instances/list\",\"autogeneratedByOpenApi\":true},{\"title\":\"Get Compute Instance\",\"description\":\"Retrieves detailed information about a specific compute instance by its ID.\\n\\n**Requirements:**\\n- Requires compute permissions (extra_permissions.compute = true)\\n- Authentication required via admin API key\\n- Instance must belong to the authenticated user's workspace\\n\\n**Key Features:**\\n- Get current instance status and configuration\\n- Access instance IP address when available\\n- View region and sector placement\\n- Check creator information\\n\\n**Common Use Cases:**\\n- Monitor specific instance status\\n- Retrieve connection details (IP address)\\n- Check instance readiness before use\\n- Audit instance configuration\\n\\nSee [fal.ai docs](https://docs.fal.ai/compute) for more details.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /compute/instances/{id}\",\"href\":\"/platform-apis/v1/compute/instances/get\",\"autogeneratedByOpenApi\":true},{\"title\":\"Create Compute Instance\",\"description\":\"$2e\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json post /compute/instances\",\"href\":\"/platform-apis/v1/compute/instances/create\",\"autogeneratedByOpenApi\":true},{\"title\":\"Delete Compute Instance\",\"description\":\"Deletes a specific compute instance by its ID. This action is irreversible.\\n\\n**Requirements:**\\n- Requires compute permissions (extra_permissions.compute = true)\\n- Authentication required via admin API key\\n- Instance must belong to the authenticated user's workspace\\n\\n**Key Features:**\\n- Permanently remove compute instances\\n- Free up compute resources\\n- Stop billing for the instance\\n- Clean up unused resources\\n\\n**Important:**\\n- This action cannot be undone\\n- All data on the instance will be lost\\n- Instance will be immediately terminated\\n- Billing stops after deletion\\n\\n**Common Use Cases:**\\n- Clean up completed workloads\\n- Remove failed or stuck instances\\n- Manage compute costs\\n- Free up quota for new instances\\n\\nSee [fal.ai docs](https://docs.fal.ai/compute) for more details.\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json delete /compute/instances/{id}\",\"href\":\"/platform-apis/v1/compute/instances/delete\",\"autogeneratedByOpenApi\":true},{\"title\":\"Platform APIs for Keys\",\"description\":\"Programmatic access to API key management, creation, and deletion\",\"href\":\"/api-reference/platform-apis/for-keys\",\"hidden\":false},{\"title\":\"List API Keys\",\"description\":\"Returns a list of all API keys belonging to the authenticated user's workspace.\\n\\n**Requirements:**\\n- Authentication required via admin API key\\n\\n**Key Features:**\\n- View all API keys with their aliases and creation dates\\n- Optionally expand to include creator information\\n- Paginated results for workspaces with many keys\\n\\n**Expansion Options:**\\n- `expand=creator_info`: Include creator_nickname and creator_email for each key\\n\\n**Common Use Cases:**\\n- Audit existing API keys\\n- Find keys by alias\\n- Monitor key creation activity\\n- Build key management interfaces\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json get /keys\",\"href\":\"/platform-apis/v1/keys/list\",\"autogeneratedByOpenApi\":true},{\"title\":\"Create API Key\",\"description\":\"Creates a new API key with the specified alias.\\n\\n**Requirements:**\\n- Authentication required via admin API key\\n\\n**Important Security Notice:**\\nThe `key_secret` is only returned once at creation time. Store it securely immediately\\nas it cannot be retrieved again. If lost, you must delete the key and create a new one.\\n\\n**Key Features:**\\n- Create API keys programmatically without UI access\\n- Assign meaningful aliases for key identification\\n- Keys are immediately active upon creation\\n\\n**Common Use Cases:**\\n- Programmatic key provisioning for CI/CD pipelines\\n- Self-serve key generation for team members\\n- Automated key rotation workflows\\n- Integration with secret management systems\",\"deprecated\":null,\"version\":null,\"openapi\":\"api-reference/platform-apis/openapi/v1.json post /keys\",\"href\":\"/platform-apis/v1/keys/create\",\"autogeneratedByOpenApi\":true},{\"title\":\"Delete API Key\",\"description\":\"Deletes an API key by its ID. This action is irreversible.\\n\\n**Requirements:**\\n- Authentication required via admin API key\\n- Key must belong to the authenticated user's workspace\\n\\n**Key Features:**\\n- Permanently revoke API key access\\n- Idempotent operation (safe to retry)\\n- Optional Idempotency-Key header for safe retries\\n\\n**Important:**\\n- This action cannot be undone\\n- Any applications using this key will immediately lose access\\n- Returns 204 even if the key doesn't exist (idempotent behavior)\\n\\n**Common Use Cases:**\\n- Revoke compromised keys\\n- Clean up unused keys\\n- Implement key rotation (delete old, create new)\\n- Offboard team members\",\"deprecated\":null,\"version\":n