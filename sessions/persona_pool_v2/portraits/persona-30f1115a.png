30227907bd.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"83734\",\"static/chunks/83734-40642d6df58ed664.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"45791\",\"static/chunks/45791-e31cbca6136076cf.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"8685\",\"static/chunks/8685-ccdbc3152c97487c.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"55016\",\"static/chunks/55016-72c83ff31408f832.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"75862\",\"static/chunks/75862-b47663e5813218cd.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"32351\",\"static/chunks/32351-477eaebe712d7bce.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"73205\",\"static/chunks/73205-a065da82f41bdf4c.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"7922\",\"static/chunks/7922-82a7ea9481767d92.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"86707\",\"static/chunks/86707-5c8a9a831fda4de1.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"37756\",\"static/chunks/37756-55f740a65628ec60.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"89841\",\"static/chunks/app/%255Fsites/%5Bsubdomain%5D/(multitenant)/%5B%5B...slug%5D%5D/page-d8a8ca695f94ede0.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\"],\"default\",1]\n"])</script><script>self.__next_f.push([1,"4c:Ta27,"])</script><script>self.__next_f.push([1,"// Serverless Access Popup\n(function() {\n  'use strict';\n  \n  // Only run on client-side\n  if (typeof window === 'undefined') return;\n  \n  function initServerlessPopup() {\n    // Check if we're on a serverless page\n    const isServerlessPage = window.location.pathname.startsWith('/serverless');\n    \n    if (!isServerlessPage) return;\n    \n    // Check if popup was previously dismissed (session-based)\n    const popupDismissed = sessionStorage.getItem('serverless-popup-dismissed');\n    \n    if (popupDismissed === 'true') return;\n    \n    // Check if popup already exists\n    if (document.getElementById('serverless-access-popup')) return;\n    \n    // Create popup HTML\n    const popupHTML = `\n      \u003cdiv id=\"serverless-access-popup\" class=\"hidden\"\u003e\n        \u003cdiv class=\"popup-header\"\u003e\n          \u003ch3 class=\"popup-title\"\u003e🔒 Need Serverless Access?\u003c/h3\u003e\n          \u003cbutton class=\"popup-close\" id=\"close-popup\" aria-label=\"Close\"\u003e×\u003c/button\u003e\n        \u003c/div\u003e\n        \u003cdiv class=\"popup-content\"\u003e\n          Don't have access to fal Serverless yet? Request access to deploy your custom models with instant GPU scaling.\n        \u003c/div\u003e\n        \u003ca href=\"https://fal.ai/dashboard/serverless-get-started\" class=\"popup-action\" target=\"_blank\" rel=\"noopener noreferrer\"\u003e\n          Request Access\n        \u003c/a\u003e\n      \u003c/div\u003e\n    `;\n    \n    // Insert popup into page\n    const tempDiv = document.createElement('div');\n    tempDiv.innerHTML = popupHTML;\n    document.body.appendChild(tempDiv.firstElementChild);\n    \n    // Show popup after a short delay\n    setTimeout(function() {\n      const popup = document.getElementById('serverless-access-popup');\n      if (popup) {\n        popup.classList.remove('hidden');\n      }\n    }, 2000);\n    \n    // Handle close button\n    const closeBtn = document.getElementById('close-popup');\n    if (closeBtn) {\n      closeBtn.addEventListener('click', function() {\n        const popup = document.getElementById('serverless-access-popup');\n        if (popup) {\n          popup.classList.add('hidden');\n          sessionStorage.setItem('serverless-popup-dismissed', 'true');\n        }\n      });\n    }\n  }\n  \n  // Initialize when DOM is ready\n  if (document.readyState === 'loading') {\n    document.addEventListener('DOMContentLoaded', initServerlessPopup);\n  } else {\n    initServerlessPopup();\n  }\n  \n  // Re-initialize on route changes (for SPA navigation)\n  let lastPath = window.location.pathname;\n  setInterval(function() {\n    if (window.location.pathname !== lastPath) {\n      lastPath = window.location.pathname;\n      initServerlessPopup();\n    }\n  }, 500);\n  \n})();\n\n"])</script><script>self.__next_f.push([1,"4d:T4d0,"])</script><script>self.__next_f.push([1,"(function () {\n  // Match any input whose aria-label or placeholder mentions \"Authorization\"\n  const MATCH =\n    'input[aria-label*=\"Authorization\" i], input[placeholder*=\"Authorization\" i]';\n\n  function harden(input) {\n    if (!input || input.dataset._hardened === \"1\") return;\n\n    // Convert to masked password-like input\n    input.setAttribute(\"type\", \"password\");\n    input.setAttribute(\"autocomplete\", \"off\");\n\n    input.dataset._hardened = \"1\";\n\n    // Protect against reversion by Mintlify’s dynamic rendering\n    const attrObserver = new MutationObserver(() =\u003e {\n      if (input.getAttribute(\"type\") !== \"password\") {\n        input.setAttribute(\"type\", \"password\");\n      }\n      if (input.getAttribute(\"autocomplete\") !== \"off\") {\n        input.setAttribute(\"autocomplete\", \"off\");\n      }\n    });\n    attrObserver.observe(input, {\n      attributes: true,\n      attributeFilter: [\"type\", \"autocomplete\"],\n    });\n  }\n\n  function scan() {\n    document.querySelectorAll(MATCH).forEach(harden);\n  }\n\n  // Run once and re-run for dynamic updates\n  requestAnimationFrame(scan);\n\n  const observer = new MutationObserver(scan);\n  observer.observe(document.documentElement, {\n    subtree: true,\n    childList: true,\n  });\n})();\n"])</script><script>self.__next_f.push([1,"4e:T7c2,"])</script><script>self.__next_f.push([1,"(function () {\n  // Ensure API key placeholders in code examples include the \"Key \" prefix\n  // Matches common patterns where Authorization header might be set without the prefix\n\n  function fixAuthorizationInCodeBlock(codeBlock) {\n    if (!codeBlock || codeBlock.dataset._keyFormatted === \"1\") return;\n\n    const content = codeBlock.textContent || codeBlock.innerText;\n    \n    // Skip if already correctly formatted with Key prefix\n    if (content.match(/Key\\s+\u003c(api-key|admin-api-key)\u003e/i)) {\n      codeBlock.dataset._keyFormatted = \"1\";\n      return;\n    }\n\n    // Check if content has api-key placeholders before doing DOM manipulation\n    if (!content.match(/\u003c(api-key|admin-api-key)\u003e/i)) {\n      codeBlock.dataset._keyFormatted = \"1\";\n      return;\n    }\n\n    // Walk through all text nodes to preserve syntax highlighting\n    const walker = document.createTreeWalker(\n      codeBlock,\n      NodeFilter.SHOW_TEXT,\n      null\n    );\n\n    const textNodes = [];\n    let node;\n    while (node = walker.nextNode()) {\n      textNodes.push(node);\n    }\n\n    // Process text nodes to add \"Key \" prefix to api-key placeholders\n    textNodes.forEach(textNode =\u003e {\n      const text = textNode.textContent;\n      \n      // Replace \u003capi-key\u003e or \u003cadmin-api-key\u003e with Key \u003capi-key\u003e / Key \u003cadmin-api-key\u003e\n      // Handles: '\u003capi-key\u003e', \"\u003capi-key\u003e\", \u003capi-key\u003e, etc.\n      const newText = text.replace(/(\u003capi-key\u003e|\u003cadmin-api-key\u003e)/gi, 'Key $1');\n      \n      if (newText !== text) {\n        textNode.textContent = newText;\n      }\n    });\n    \n    codeBlock.dataset._keyFormatted = \"1\";\n  }\n\n  function scanAndFix() {\n    // Fix all code blocks within code groups only\n    document.querySelectorAll('.code-group code').forEach(fixAuthorizationInCodeBlock);\n  }\n\n  // Run once and re-run for dynamic updates\n  requestAnimationFrame(scanAndFix);\n\n  const observer = new MutationObserver(scanAndFix);\n  observer.observe(document.documentElement, {\n    subtree: true,\n    childList: true,\n  });\n})();\n\n"])</script><script>self.__next_f.push([1,"49:[\"$\",\"$L4b\",null,{\"customJsDisabled\":false,\"jsFiles\":[{\"_id\":\"68fea4c0ecd2c7b3d78e919f\",\"subdomain\":\"fal-d8505a2e\",\"filePath\":\"serverless-popup.js\",\"__v\":0,\"content\":\"$4c\"},{\"_id\":\"690391d5ecd2c7b