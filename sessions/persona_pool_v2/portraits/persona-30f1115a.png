5\",\"static/chunks/8685-ccdbc3152c97487c.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"55016\",\"static/chunks/55016-72c83ff31408f832.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"75862\",\"static/chunks/75862-b47663e5813218cd.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"32351\",\"static/chunks/32351-477eaebe712d7bce.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"73205\",\"static/chunks/73205-a065da82f41bdf4c.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"7922\",\"static/chunks/7922-82a7ea9481767d92.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"86707\",\"static/chunks/86707-5c8a9a831fda4de1.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"37756\",\"static/chunks/37756-55f740a65628ec60.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"89841\",\"static/chunks/app/%255Fsites/%5Bsubdomain%5D/(multitenant)/%5B%5B...slug%5D%5D/page-d8a8ca695f94ede0.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\"],\"Background\",1]\n"])</script><script>self.__next_f.push([1,"48:T41f2,"])</script><script>self.__next_f.push([1,"/* Focal Medium -- scoped to a separate family so it doesn't affect global headings */\n@font-face {\n  font-family: 'Focal Medium';\n  src: url('https://mintlify-assets.b-cdn.net/fonts/Focal-Medium-Web.woff2') format('woff2');\n  font-weight: 500;\n  font-style: normal;\n  font-display: swap;\n}\n\n/* Page decoration -- geometric shapes top right */\n#content-area::after {\n  content: '';\n  position: fixed;\n  top: 80px;\n  right: 24px;\n  width: 85px;\n  height: 225px;\n  background: url('/docs/images/page-decoration.svg') no-repeat center;\n  background-size: contain;\n  pointer-events: none;\n  z-index: 10;\n  opacity: 0.8;\n}\n\n.dark #content-area::after {\n  opacity: 0.4;\n}\n\n@media (max-width: 1325px) {\n  #content-area::after {\n    display: none;\n  }\n}\n\n/* Widen the central content/prose column */\n#content-area,\n#content-area \u003e div,\n[class*=\"prose\"] {\n  max-width: 900px !important;\n}\n\n/* Hero section styling */\n#hero-section {\n  position: relative;\n}\n\n#hero-section \u003e * {\n  position: relative;\n  z-index: 1;\n}\n\n/* Make first-level sidebar items bold */\nul#sidebar-group \u003e li \u003e a,\nul#sidebar-group \u003e li \u003e button {\n  font-weight: 600 !important;\n}\n\n/* Align child items with header text when group has an icon */\n/* The icon is 14px (0.875rem) + gap of 10px (0.625rem) = 24px offset */\nli[data-group-tag] \u003e ul li \u003e a,\nli[data-group-tag] \u003e ul li \u003e button {\n  margin-left: 2rem !important;\n}\n\n\n/* Navbar background - commented out for now */\n/* #navbar .bg-background-light {\n  background-color: #f7f7f8 !important;\n} */\n\n\n#sidebar-content {\n  /*background: #f2f0f5aa !important;*/\n  padding-left: 1rem;\n  overflow-x: hidden;\n  width: 350px !important;\n  min-width: 350px !important;\n}\n\n/* Widen sidebar and shift content/navbar to match */\n@media (min-width: 1024px) {\n  #sidebar {\n    width: 350px !important;\n  }\n\n  #content-container {\n    margin-left: 350px !important;\n  }\n\n  #navbar-transition-maple {\n    left: 350px !important;\n  }\n}\n\n#sidebar-content {\n  background-color: #f7f7f8 !important;   \n}\n\n.dark #sidebar-content {\n  background-color: #14151A !important;\n}\n\n/* Match sidebar bottom links (Contact Sales, Login) with sidebar */\n@media (min-width: 1024px) {\n  ul.w-\\[calc\\(19rem-1px\\)\\] {\n    width: 350px !important;\n    background-color: #f7f7f8 !important;\n  }\n\n  .dark ul.w-\\[calc\\(19rem-1px\\)\\] {\n    background-color: #14151A !important;\n  }\n}\n\n\n#sidebar-content::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100vw;\n  width: 100vw;\n  height: 100%;\n  background-color: #f7f7f8;\n  z-index: -1;\n}\n\n.dark #sidebar-content::before {\n  background-color: #14151A;\n}\n\n\n\n\n/* Uniform card image heights */\n[class*=\"CardGroup\"] a img,\n[class*=\"card-group\"] a img,\n.card-group a img {\n  height: 160px !important;\n  object-fit: cover !important;\n  width: 100% !important;\n}\n\n/* Limit code block height and add internal scrolling */\n.code-group pre,\npre[class*=\"language-\"] {\n  max-height: 600px;\n  overflow-y: auto;\n}\n\n/* Expand middle content area with responsive scaling */\n@media (min-width: 1024px) {\n  div[id=\"content-container\"] {\n    max-width: 100% !important;\n  }\n  \n  /* Override Mintlify's default max-width constraint */\n  .peer.is-not-center~.peer-\\[\\.is-not-center\\]\\:max-w-8xl,\n  .peer.is-not-custom~.peer-\\[\\.is-not-custom\\]\\:max-w-8xl,\n  .max-w-8xl {\n    max-width: 100% !important;\n  }\n}\n\n\n\n/* Large screens: 75% width */\n@media (max-width: 1440px) {\n  .peer.is-not-center~.peer-\\[\\.is-not-center\\]\\:max-w-8xl,\n  .peer.is-not-custom~.peer-\\[\\.is-not-custom\\]\\:max-w-8xl,\n  .max-w-8xl {\n    max-width: 100% !important;\n  }\n}\n\n\n\n/* Large screens: 75% width */\n@media (min-width: 1920px) {\n  .peer.is-not-center~.peer-\\[\\.is-not-center\\]\\:max-w-8xl,\n  .peer.is-not-custom~.peer-\\[\\.is-not-custom\\]\\:max-w-8xl,\n  .max-w-8xl {\n    max-width: 75% !important;\n  }\n}\n\n\n*:not(li.toc-item):not(li.toc-item *):not(.link):not(.flex-1):not(.flex-1 *) {\n  border-radius: 4px !important;\n}\n\n/* Square search bar in navbar */\n#navbar input,\n#navbar [id*=\"search\"],\nnav input,\nheader input {\n  border-radius: 4px !important;\n}\n\n/* Small border radius for navbar buttons */\n#navbar button,\n#navbar a,\n#navbar a \u003e *,\nnav button,\nnav a,\nnav a \u003e *,\nheader button,\nheader a,\nheader a \u003e * {\n  border-radius: 4px !important;\n}\n\n/* Ensure Login button specifically has 4px radius */\na[href*=\"login\"],\na[href*=\"login\"] \u003e * {\n  border-radius: 4px !important;\n}\n\n/* Remove border radius from logo to prevent cutoff */\n#navbar a[href=\"https://fal.ai/\"],\n#navbar a[href=\"https://fal.ai/\"] \u003e *,\nnav a[href=\"https://fal.ai/\"],\nnav a[href=\"https://fal.ai/\"] \u003e *,\nheader a[href=\"https://fal.ai/\"],\nheader a[href=\"https://fal.ai/\"] \u003e * {\n  border-radius: 0 !important;\n}\n\nbody {\n  font-feature-settings: 'ss01' on !important;\n}\n\n/* Tooltip trigger styling - purple to match brand */\n[data-tooltip],\n.tooltip-trigger,\nspan[style*=\"border-bottom\"][style*=\"dotted\"],\nbutton[data-state] \u003e span[style*=\"dotted\"],\nspan[class*=\"tooltip\"],\n[data-radix-tooltip-trigger] {\n  border-bottom-color: #5718C0 !important;\n  color: #5718C0 !important;\n  text-decoration-color: #5718C0 !important;\n}\n\n.dark [data-tooltip],\n.dark .tooltip-trigger,\n.dark span[style*=\"border-bottom\"][style*=\"dotted\"],\n.dark button[data-state] \u003e span[style*=\"dotted\"],\n.dark span[class*=\"tooltip\"],\n.dark [data-radix-tooltip-trigger] {\n  border-bottom-color: #C0B1FF !important;\n  color: #C0B1FF !important;\n  text-decoration-color: #C0B1FF !important;\n}\n\n/* Tooltip popup CTA link styling */\n[data-radix-tooltip-content] a,\n[role=\"tooltip\"] a,\n[data-state=\"delayed-open\"] ~ [data-radix-tooltip-content] a,\ndiv[class*=\"tooltip\"] a[href] {\n  color: #C0B1FF !important;\n  text-decoration: underline !important;\n  text-decoration-color: #C0B1FF !important;\n}\n\n[data-radix-tooltip-content] a:hover,\n[role=\"tooltip\"] a:hover,\ndiv[class*=\"tooltip\"] a[href]:hover {\n  color: #ddd0ff !important;\n  text-decoration-color: #ddd0ff !important;\n}\n\n/* MCP Card hover styles */\n.mcp-card:hover {\n  border-color: #a78bfa !important;\n  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;\n}\n\n.dark .mcp-card:hover {\n  border-color: #8b5cf6 !important;\n}\n\n/* Serverless Access Popup */\n#serverless-access-popup {\n  position: fixed;\n  bottom: 20px;\n  right: 20px;\n  max-width: 400px;\n  background: white;\n  border: 1px solid #e5e7eb;\n  border-radius: 8px;\n  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);\n  padding: 20px;\n  z-index: 9999;\n  animation: slideInUp 0.3s ease-out;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;\n}\n\n.dark #serverless-access-popup {\n  background: #1f2937;\n  border-color: #374151;\n  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);\n}\n\n#serverless-access-popup.hidden {\n  display: none;\n}\n\n@keyframes slideInUp {\n  from {\n    transform: translateY(100px);\n    opacity: 0;\n  }\n  to {\n    transform: translateY(0);\n    opacity: 1;\n  }\n}\n\n#serverless-access-popup .popup-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: flex-start;\n  margin-bottom: 12px;\n}\n\n#serverless-access-popup .popup-title {\n  font-size: 16px;\n  font-weight: 600;\n  color: #111827;\n  margin: 0;\n}\n\n.dark #serverless-access-popup .popup-title {\n  color: #f9fafb;\n}\n\n#serverless-access-popup .popup-close {\n  background: none;\n  border: none;\n  font-size: 20px;\n  color: #6b7280;\n  cursor: pointer;\n  padding: 0;\n  width: 24px;\n  height: 24px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  border-radius: 4px;\n  transition: background-color 0.2s;\n}\n\n#serverless-access-popup .popup-close:hover {\n  background-color: #f3f4f6;\n  color: #111827;\n}\n\n.dark #serverless-access-popup .popup-close:hover {\n  background-color: #374151;\n  color: #f9fafb;\n}\n\n#serverless-access-popup .popup-content {\n  color: #4b5563;\n  font-size: 14px;\n  line-height: 1.6;\n  margin-bottom: 16px;\n}\n\n.dark #serverless-access-popup .popup-content {\n  color: #d1d5db;\n}\n\n#serverless-access-popup .popup-action {\n  display: inline-block;\n  background-color: #5718C0;\n  color: white;\n  padding: 10px 16px;\n  border-radius: 6px;\n  text-decoration: none;\n  font-size: 14px;\n  font-weight: 500;\n  transition: background-color 0.2s;\n  border: none;\n  cursor: pointer;\n}\n\n#serverless-access-popup .popup-action:hover {\n  background-color: #4612a0;\n  color: white;\n}\n\n@media (max-width: 640px) {\n  #serverless-access-popup {\n    left: 20px;\n    right: 20px;\n    max-width: none;\n  }\n}\n\nbutton[aria-label=\"Try it\"], button[aria-label=\"Send\"], .tryit-button {\n  background-color: rgb(var(--primary-dark) / var(--tw-bg-opacity));\n}\n\n/* Auth header is not required for model search */\nhtml:has([content=\"Model search - fal\"]) #authorization-authorization [data-component-part=\"field-required-pill\"],\nhtml:has([content=\"Model search - fal\"]) [title=\"Authorization\"] [data-component-part=\"field-required-pill\"] {\n  display: none !important;\n}\n\n/* Breaking Change tag styling */\n[data-tag=\"Breaking Change\"],\n.tag[data-tag=\"Breaking Change\"],\nspan:has-text(\"Breaking Change\") {\n  background-color: #fee2e2 !important;\n  color: #991b1b !important;\n  border: 1px solid #fca5a5 !important;\n  font-weight: 600 !important;\n}\n\n.dark [data-tag=\"Breaking Change\"],\n.dark .tag[data-tag=\"Breaking Change\"],\n.dark span:has-text(\"Breaking Change\") {\n  background-color: #7f1d1d !important;\n  color: #fecaca !important;\n  border: 1px solid #991b1b !important;\n}\n\n/* Add warning icon for breaking changes */\ndiv:has(\u003e [data-tag=\"Breaking Change\"]) {\n  border-left: 4px solid #dc2626 !important;\n  padding-left: 1rem !important;\n}\n\n.dark div:has(\u003e [data-tag=\"Breaking Change\"]) {\n  border-left-color: #ef4444 !important;\n}\n\n/* Hide default page title and description on docs hero page */\nbody:has(#docs-hero-page) #content-area \u003e header,\nbody:has(#docs-hero-page) article \u003e header:first-child,\nbody:has(#docs-hero-page) .prose \u003e h1:first-child,\nbody:has(#docs-hero-page) [class*=\"PageHeader\"],\nbody:has(#docs-hero-page) [class*=\"page-header\"] {\n  display: none !important;\n}\n\n/* Hero Badge */\n.fal-hero-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 0.5rem;\n  padding: 0.375rem 0.875rem;\n  background: rgba(87, 24, 192, 0.1);\n  border: 1px solid rgba(87, 24, 192, 0.25);\n  border-radius: 4px;\n  font-size: 0.75rem;\n  color: #5718C0;\n  margin-bottom: 1.25rem;\n  font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Code', monospace;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n  font-weight: 500;\n}\n\n.dark .fal-hero-badge {\n  background: rgba(87, 24, 192, 0.15);\n  border-color: rgba(87, 24, 192, 0.35);\n  color: #c0b1ff;\n}\n\n.fal-badge-dot {\n  width: 6px;\n  height: 6px;\n  background: #00ffcc;\n  border-radius: 50%;\n  animation: falPulse 2s ease-in-out infinite;\n}\n\n@keyframes falPulse {\n  0%, 100% { opacity: 1; transform: scale(1); }\n  50% { opacity: 0.4; transform: scale(0.8); }\n}\n\n/* Hero Title */\n.fal-hero-title {\n  font-family: 'Focal Medium', 'Focal', sans-serif !important;\n  font-size: 56px !important;\n  font-weight: 500 !important;\n  line-height: 1 !important;\n  margin: 16px 0 10px 0 !important;\n  padding: 0 !important;\n  letter-spacing: -1.12px !important;\n  color: #242426 !important;\n}\n\n.dark .fal-hero-title {\n  color: #fafafa !important;\n}\n\n.fal-hero-subtitle {\n  font-family: 'Focal Medium', 'Focal', sans-serif;\n  font-size: 20px;\n  font-weight: 500;\n  line-height: 1;\n  letter-spacing: -0.4px;\n  color: #242426;\n  margin-bottom: 10px;\n}\n\n.dark .fal-hero-subtitle {\n  color: #fafafa;\n}\n\n/* Hero Body Text */\n.fal-hero-body {\n  font-size: 16px;\n  line-height: 1.4;\n  margin-bottom: 1rem;\n  color: #787881;\n  letter-spacing: -0.32px;\n}\n\n.fal-hero-body strong {\n  color: #242426;\n}\n\n.dark .fal-hero-body strong {\n  color: #fafafa;\n}\n\n/* Hero Search Bar */\n.fal-hero-search {\n  display: flex;\n  align-items: center;\n  width: 100%;\n  max-width: 360px;\n  padding: 8px 10px;\n  font-size: 13px;\n  color: #9ca3af;\n  background: white;\n  border: 1px solid rgba(18, 18, 22, 0.1);\n  cursor: pointer;\n  text-align: left;\n  transition: border-color 0.2s;\n  margin-bottom: 1rem;\n}\n\n.fal-hero-search:hover {\n  border-color: rgba(18, 18, 22, 0.2);\n}\n\n.dark .fal-hero-search {\n  background: #1f2937;\n  border-color: rgba(255, 255, 255, 0.1);\n  color: #6b7280;\n}\n\n.fal-hero-search-icon {\n  width: 14px;\n  height: 14px;\n  margin-right: 8px;\n  flex-shrink: 0;\n  color: #787881;\n}\n\n.fal-hero-search-text {\n  flex: 1;\n}\n\n.fal-hero-mcp-link {\n  display: flex;\n  align-items: center;\n  gap: 5px;\n  margin-left: auto;\n  padding: 3px 8px;\n  font-size: 11px;\n  font-weight: 600;\n  color: #5718C0 !important;\n  background: rgba(133, 83, 255, 0.08);\n  text-decoration: none !important;\n  white-space: nowrap;\n  transition: background 0.2s;\n}\n\n.fal-hero-mcp-link:hover {\n  background: rgba(133, 83, 255, 0.15);\n}\n\n.dark .fal-hero-mcp-link {\n  color: #C0B1FF !important;\n  background: rgba(133, 83, 255, 0.15);\n}\n\n.dark .fal-hero-mcp-link:hover {\n  background: rgba(133, 83, 255, 0.25);\n}\n\n/* Stats Row */\n.fal-stats-row {\n  display: flex;\n  gap: 0.5rem;\n  flex-wrap: wrap;\n  margin-top: 1.5rem;\n}\n\n.fal-stat-item {\n  position: relative;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  min-width: 99px;\n}\n\n.fal-stat-value {\n  font-family: 'Focal Medium', 'Focal', sans-serif;\n  font-size: 24px;\n  font-weight: 500;\n  line-height: 1;\n  letter-spacing: -0.4px;\n  color: #242426;\n  cursor: default;\n}\n\n.dark .fal-stat-value {\n  color: #fafafa;\n}\n\n.fal-stat-label {\n  font-size: 14px;\n  font-weight: 500;\n  line-height: 1.4;\n  letter-spacing: -0.28px;\n  color: #787881;\n}\n\n/* Hero Layout */\n.fal-hero-section {\n  display: flex;\n  gap: 2rem;\n  align-items: flex-start;\n  margin-bottom: 1.5rem;\n}\n\n.fal-hero-text {\n  flex: 1;\n  min-width: 0;\n}\n\n.fal-hero-image {\n  flex: 1;\n  min-width: 0;\n}\n\n/* Hero Image */\n.fal-hero-image img {\n  width: 100%;\n  height: auto;\n  display: block;\n}\n\n.fal-hero-img-dark {\n  display: none !important;\n}\n\n.dark .fal-hero-img-light {\n  display: none !important;\n}\n\n.dark .fal-hero-img-dark {\n  display: block !important;\n}\n\n.dark .fal-hero-img-dark {\n  display: block !important;\n}\n\n/* Feature Card Hover Enhancement */\n.fal-feature-card {\n  transition: all 0.3s ease !important;\n  position: relative;\n  overflow: hidden;\n}\n\n.fal-feature-card:hover {\n  transform: translateY(-2px);\n}\n\n/* Responsive adjustments */\n@media (max-width: 768px) {\n  .fal-hero-section {\n    flex-direction: column;\n    align-items: center;\n  }\n\n  .fal-hero-text {\n    width: 100%;\n  }\n\n  .fal-stats-row {\n    gap: 1rem;\n  }\n  \n  .fal-stat-value {\n    font-size: 18px;\n  }\n\n  .fal-hero-image {\n    display: flex;\n    justify-content: center;\n    width: 100%;\n  }\n\n  .fal-hero-image img {\n    width: auto;\n    max-width: 100%;\n    max-height: 260px;\n  }\n}\n\n/* ============================================\n   FAL Platform Lifecycle Steps\n   ============================================ */\n\n.fal-lifecycle-step {\n  position: relative;\n  margin-bottom: 1rem;\n  border-radius: 8px;\n  overflow: hidden;\n}\n\n.fal-lifecycle-step.serverless {\n  background: linear-gradient(135deg, rgba(51, 134, 254, 0.1) 0%, rgba(51, 134, 254, 0.02) 100%);\n  border-left: 3px solid #3386FE;\n}\n\n.dark .fal-lifecycle-step.serverless {\n  background: linear-gradient(135deg, rgba(51, 134, 254, 0.15) 0%, rgba(51, 134, 254, 0.05) 100%);\n}\n\n.fal-lifecycle-step.modelapis {\n  background: linear-gradient(135deg, rgba(133, 83, 255, 0.1) 0%, rgba(133, 83, 255, 0.02) 100%);\n  border-left: 3px solid #8553FF;\n}\n\n.dark .fal-lifecycle-step.modelapis {\n  background: linear-gradient(135deg, rgba(133, 83, 255, 0.2) 0%, rgba(133, 83, 255, 0.05) 100%);\n}\n\n.fal-step-header {\n  display: flex;\n  align-items: center;\n  gap: 0.75rem;\n  padding: 1rem 1.25rem 0.5rem;\n}\n\n.fal-step-number {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 28px;\n  height: 28px;\n  border-radius: 50%;\n  font-size: 0.875rem;\n  font-weight: 600;\n  flex-shrink: 0;\n}\n\n.fal-lifecycle-step.serverless .fal-step-number {\n  background: rgba(51, 134, 254, 0.15);\n  color: #1841B5;\n}\n\n.dark .fal-lifecycle-step.serverless .fal-step-number {\n  background: rgba(51, 134, 254, 0.25);\n  color: #8EC8FF;\n}\n\n.fal-lifecycle-step.modelapis .fal-step-number {\n  background: rgba(133, 83, 255, 0.15);\n  color: #5718C0;\n}\n\n.dark .fal-lifecycle-step.modelapis .fal-step-number {\n  background: rgba(133, 83, 255, 0.25);\n  color: #C0B1FF;\n}\n\n.fal-step-title {\n  font-size: 1.125rem;\n  font-weight: 600;\n  flex-grow: 1;\n}\n\n.fal-step-logo {\n  height: 18px;\n  opacity: 0.9;\n}\n\n.fal-lifecycle-step .fal-step-logo {\n  filter: none;\n}\n\n.fal-step-content {\n  padding: 0 1.25rem 1rem;\n}\n\n.fal-step-content p:first-child {\n  margin-top: 0;\n}\n\n.fal-step-content ul {\n  margin-bottom: 0;\n}\n\n/* Responsive */\n@media (max-width: 640px) {\n  .fal-step-header {\n    flex-wrap: wrap;\n  }\n  \n  .fal-step-logo {\n    order: -1;\n    width: 100%;\n    margin-bottom: 0.5rem;\n    height: 16px;\n  }\n}\n\n\n"])</script><script>self.__next_f.push([1,"44:[\"$\",\"$L45\",null,{\"children\":[[\"$\",\"$L26\",null,{\"id\":\"_mintlify-page-mode-script\",\"strategy\":\"beforeInteractive\",\"dangerouslySetInnerHTML\":{\"__html\":\"document.documentElement.setAttribute('data-page-mode', 'none');\"}}],[\"$\",\"$L46\",null,{\"theme\":\"maple\"}],[\"$\",\"$L47\",null,{\"docsConfig\":\"$1c:props:children:props:children:props:docsConfig\",\"pageMetadata\":\"$1c:props:children:props:value:pageMetadata\"}],[[\"$\",\"style\",\"0\",{\"data-custom-css-index\":0,\"data-custom-css-path\":\"style.css\",\"dangerouslySetInnerHTML\":{\"__html\":\"$48\"}}]],\"$L49\",\"$L4a\"]}]\n"])</script><script>self.__next_f.push([1,"4b:I[14162,[\"73473\",\"static/chunks/891cff7f-dcf0b8e94fd9e2cd.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"53016\",\"static/chunks/cfdfcc00-442051842d4b5e4f.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"41725\",\"static/chunks/d30757c7-4ce3b53815c6f230.js?dpl=dpl_GsujBoBSPXqgNqvfPayvrrsEQ4Tw\",\"53105\",\"static/chunks/53105-c5098dd7faa69cf4.js?dpl=dpl_Gsuj