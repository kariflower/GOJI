<span class="line"><span style="color:#116329;--shiki-dark:#9CDCFE">    &quot;input&quot;</span><span style="color:#1F2328;--shiki-dark:#D4D4D4">: </span><span style="color:#0A3069;--shiki-dark:#CE9178">&quot;https://example.com/short_video.mp4&quot;</span></span>
