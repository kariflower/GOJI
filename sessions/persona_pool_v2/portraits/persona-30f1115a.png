\")?.classList.contains(\"advanced-footer\")||c)return;let d=document.documentElement.getAttribute(\"data-page-mode\"),e=document.getElementById(\"navbar\"),f=document.getElementById(\"navigation-items\"),g=document.getElementById(\"sidebar\"),h=document.getElementById(\"footer\"),i=document.getElementById(\"table-of-contents-content\"),j=16*a;if(!h||\"center\"===d)return;let k=h.getBoundingClientRect().top,l=window.innerHeight-k,m=(f?.clientHeight??0)+j+32*(\"mint\"===b||\"linden\"===b);if(g&&f)if(l>0){let a=Math.max(0,m-k);g.style.bottom=`${l}px`,g.style.top=`${j-a}px`}else g.style.bottom=\"\",g.style.top=`${a}rem`,g.style.height=\"auto\";i&&e&&(l>0?i.style.top=\"custom\"===d?`${e.clientHeight-l}px`:`${40+e.clientHeight-l}px`:i.style.top=\"\")})(\n  (function m(a,b,c){let d=document.documentElement.getAttribute(\"data-banner-state\"),e=2.5*!!(null!=d?\"visible\"===d:b),f=3*!!a,g=4,h=e+g+f;switch(c){case\"mint\":case\"palm\":break;case\"aspen\":f=2.5*!!a,g=3.5,h=e+f+g;break;case\"luma\":g=3,h=e+g;break;case\"linden\":g=4,h=e+g;break;case\"almond\":g=3.5,h=e+g;break;case\"sequoia\":f=3*!!a,g=3,h=e+g+f}return h})(true, false, \"maple\"),\n  \"maple\",\n)","id":"_mintlify-footer-and-sidebar-scroll-script"}])</script><span class="fixed inset-0 bg-background-light dark:bg-background-dark -z-10 pointer-events-none" id="background-color"></span><style data-custom-css-index="0" data-custom-css-path="style.css">/* Focal Medium -- scoped to a separate family so it doesn't affect global headings */
@font-face {
  font-family: 'Focal Medium';
  src: url('https://mintlify-assets.b-cdn.net/fonts/Focal-Medium-Web.woff2') format('woff2');
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}

/* Page decoration -- geometric shapes top right */
#content-area::after {
  content: '';
  position: fixed;
  top: 80px;
  right: 24px;
  width: 85px;
  height: 225px;
  background: url('/docs/images/page-decoration.svg') no-repeat center;
  background-size: contain;
  pointer-events: none;
  z-index: 10;
  opacity: 0.8;
}

.dark #content-area::after {
  opacity: 0.4;
}

@media (max-width: 1325px) {
  #content-area::after {
    display: none;
  }
}

/* Widen the central content/prose column */
#content-area,
#content-area > div,
[class*="prose"] {
  max-width: 900px !important;
}

/* Hero section styling */
#hero-section {
  position: relative;
}

#hero-section > * {
  position: relative;
  z-index: 1;
}

/* Make first-level sidebar items bold */
ul#sidebar-group > li > a,
ul#sidebar-group > li > button {
  font-weight: 600 !important;
}

/* Align child items with header text when group has an icon */
/* The icon is 14px (0.875rem) + gap of 10px (0.625rem) = 24px offset */
li[data-group-tag] > ul li > a,
li[data-group-tag] > ul li > button {
  margin-left: 2rem !important;
}


/* Navbar background - commented out for now */
/* #navbar .bg-background-light {
  background-color: #f7f7f8 !important;
} */


#sidebar-content {
  /*background: #f2f0f5aa !important;*/
  padding-left: 1rem;
  overflow-x: hidden;
  width: 350px !important;
  min-width: 350px !important;
}

/* Widen sidebar and shift content/navbar to match */
@media (min-width: 1024px) {
  #sidebar {
    width: 350px !important;
  }

  #content-container {
    margin-left: 350px !important;
  }

  #navbar-transition-maple {
    left: 350px !important;
  }
}

#sidebar-content {
  background-color: #f7f7f8 !important;   
}

.dark #sidebar-content {
  background-color: #14151A !important;
}

/* Match sidebar bottom links (Contact Sales, Login) with sidebar */
@media (min-width: 1024px) {
  ul.w-\[calc\(19rem-1px\)\] {
    width: 350px !important;
    background-color: #f7f7f8 !important;
  }

  .dark ul.w-\[calc\(19rem-1px\)\] {
    background-color: #14151A !important;
  }
}


#sidebar-content::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100vw;
  width: 100vw;
  height: 100%;
  background-color: #f7f7f8;
  z-index: -1;
}

.dark #sidebar-content::before {
  background-color: #14151A;
}




/* Uniform card image heights */
[class*="CardGroup"] a img,
[class*="card-group"] a img,
.card-group a img {
  height: 160px !important;
  object-fit: cover !important;
  width: 100% !important;
}

/* Limit code block height and add internal scrolling */
.code-group pre,
pre[class*="language-"] {
  max-height: 600px;
  overflow-y: auto;
}

/* Expand middle content area with responsive scaling */
@media (min-width: 1024px) {
  div[id="content-container"] {
    max-width: 100% !important;
  }
  
  /* Override Mintlify's default max-width constraint */
  .peer.is-not-center~.peer-\[\.is-not-center\]\:max-w-8xl,
  .peer.is-not-custom~.peer-\[\.is-not-custom\]\:max-w-8xl,
  .max-w-8xl {
    max-width: 100% !important;
  }
}



/* Large screens: 75% width */
@media (max-width: 1440px) {
  .peer.is-not-center~.peer-\[\.is-not-center\]\:max-w-8xl,
  .peer.is-not-custom~.peer-\[\.is-not-custom\]\:max-w-8xl,
  .max-w-8xl {
    max-width: 100% !important;
  }
}



/* Large screens: 75% width */
@media (min-width: 1920px) {
  .peer.is-not-center~.peer-\[\.is-not-center\]\:max-w-8xl,
  .peer.is-not-custom~.peer-\[\.is-not-custom\]\:max-w-8xl,
  .max-w-8xl {
    max-width: 75% !important;
  }
}


*:not(li.toc-item):not(li.toc-item *):not(.link):not(.flex-1):not(.flex-1 *) {
  border-radius: 4px !important;
}

/* Square search bar in navbar */
#navbar input,
#navbar [id*="search"],
nav input,
header input {
  border-radius: 4px !important;
}

/* Small border radius for navbar buttons */
#navbar button,
#navbar a,
#navbar a > *,
nav button,
nav a,
nav a > *,
header button,
header a,
header a > * {
  border-radius: 4px !important;
}

/* Ensure Login button specifically has 4px radius */
a[href*="login"],
a[href*="login"] > * {
  border-radius: 4px !important;
}

/* Remove border radius from logo to prevent cutoff */
#navbar a[href="https://fal.ai/"],
#navbar a[href="https://fal.ai/"] > *,
nav a[href="https://fal.ai/"],
nav a[href="https://fal.ai/"] > *,
header a[href="https://fal.ai/"],
header a[href="https://fal.ai/"] > * {
  border-radius: 0 !important;
}

body {
  font-feature-settings: 'ss01' on !important;
}

/* Tooltip trigger styling - purple to match brand */
[data-tooltip],
.tooltip-trigger,
span[style*="border-bottom"][style*="dotted"],
button[data-state] > span[style*="dotted"],
span[class*="tooltip"],
[data-radix-tooltip-trigger] {
  border-bottom-color: #5718C0 !important;
  color: #5718C0 !important;
  text-decoration-color: #5718C0 !important;
}

.dark [data-tooltip],
.dark .tooltip-trigger,
.dark span[style*="border-bottom"][style*="dotted"],
.dark button[data-state] > span[style*="dotted"],
.dark span[class*="tooltip"],
.dark [data-radix-tooltip-trigger] {
  border-bottom-color: #C0B1FF !important;
  color: #C0B1FF !important;
  text-decoration-color: #C0B1FF !important;
}

/* Tooltip popup CTA link styling */
[data-radix-tooltip-content] a,
[role="tooltip"] a,
[data-state="delayed-open"] ~ [data-radix-tooltip-content] a,
div[class*="tooltip"] a[href] {
  color: #C0B1FF !important;
  text-decoration: underline !important;
  text-decoration-color: #C0B1FF !important;
}

[data-radix-tooltip-content] a:hover,
[role="tooltip"] a:hover,
div[class*="tooltip"] a[href]:hover {
  color: #ddd0ff !important;
  text-decoration-color: #ddd0ff !important;
}

/* MCP Card hover styles */
.mcp-card:hover {
  border-color: #a78bfa !important;
  box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06) !important;
}

.dark .mcp-card:hover {
  border-color: #8b5cf6 !important;
}

/* Serverless Access Popup */
#serverless-access-popup {
  position: fixed;
  bottom: 20px;
  right: 20px;
  max-width: 400px;
  background: white;
  border: 1px solid #e5e7eb;
  border-radius: 8px;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  padding: 20px;
  z-index: 9999;
  animation: slideInUp 0.3s ease-out;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif;
}

.dark #serverless-access-popup {
  background: #1f2937;
  border-color: #374151;
  box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
}

#serverless-access-popup.hidden {
  display: none;
}

@keyframes slideInUp {
  from {
    transform: translateY(100px);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

#serverless-access-popup .popup-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

#serverless-access-popup .popup-title {
  font-size: 16px;
  font-weight: 600;
  color: #111827;
  margin: 0;
}

.dark #serverless-access-popup .popup-title {
  color: #f9fafb;
}

#serverless-access-popup .popup-close {
  background: none;
  border: none;
  font-size: 20px;
  color: #6b7280;
  cursor: pointer;
  padding: 0;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  transition: background-color 0.2s;
}

#serverless-access-popup .popup-close:hover {
  background-color: #f3f4f6;
  color: #111827;
}

.dark #serverless-access-popup .popup-close:hover {
  background-color: #374151;
  color: #f9fafb;
}

#serverless-access-popup .popup-content {
  color: #4b5563;
  font-size: 14px;
  line-height: 1.6;
  margin-bottom: 16px;
}

.dark #serverless-access-popup .popup-content {
  color: #d1d5db;
}

#serverless-access-popup .popup-action {
  display: inline-block;
  background-color: #5718C0;
  color: white;
  padding: 10px 16px;
  border-radius: 6px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 500;
  transition: background-color 0.2s;
  border: none;
  cursor: pointer;
}

#serverless-access-popup .popup-action:hover {
  background-color: #4612a0;
  color: white;
}

@media (max-width: 640px) {
  #serverless-access-popup {
    left: 20px;
    right: 20px;
    max-width: none;
  }
}

button[aria-label="Try it"], button[aria-label="Send"], .tryit-button {
  background-color: rgb(var(--primary-dark) / var(--tw-bg-opacity));
}

/* Auth header is not required for model search */
html:has([content="Model search - fal"]) #authorization-authorization [data-component-part="field-required-pill"],
html:has([content="Model search - fal"]) [title="Authorization"] [data-component-part="field-required-pill"] {
  display: none !important;
}

/* Breaking Change tag styling */
[data-tag="Breaking Change"],
.tag[data-tag="Breaking Change"],
span:has-text("Breaking Change") {
  background-color: #fee2e2 !important;
  color: #991b1b !important;
  border: 1px solid #fca5a5 !important;
  font-weight: 600 !important;
}

.dark [data-tag="Breaking Change"],
.dark .tag[data-tag="Breaking Change"],
.dark span:has-text("Breaking Change") {
  background-color: #7f1d1d !important;
  color: #fecaca !important;
  border: 1px solid #991b1b !important;
}

/* Add warning icon for breaking changes */
div:has(> [data-tag="Breaking Change"]) {
  border-left: 4px solid #dc2626 !important;
  padding-left: 1rem !important;
}

.dark div:has(> [data-tag="Breaking Change"]) {
  border-left-color: #ef4444 !important;
}

/* Hide default page title and description on docs hero page */
body:has(#docs-hero-page) #content-area > header,
body:has(#docs-hero-page) article > header:first-child,
body:has(#docs-hero-page) .prose > h1:first-child,
body:has(#docs-hero-page) [class*="PageHeader"],
body:has(#docs-hero-page) [class*="page-header"] {
  display: none !important;
}

/* Hero Badge */
.fal-hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.375rem 0.875rem;
  background: rgba(87, 24, 192, 0.1);
  border: 1px solid rgba(87, 24, 192, 0.25);
  border-radius: 4px;
  font-size: 0.75rem;
  color: #5718C0;
  margin-bottom: 1.25rem;
  font-family: 'SF Mono', 'Monaco', 'Inconsolata', 'Fira Code', monospace;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-weight: 500;
}

.dark .fal-hero-badge {
  background: rgba(87, 24, 192, 0.15);
  border-color: rgba(87, 24, 192, 0.35);
  color: #c0b1ff;
}

.fal-badge-dot {
  width: 6px;
  height: 6px;
  background: #00ffcc;
  border-radius: 50%;
  animation: falPulse 2s ease-in-out infinite;
}

@keyframes falPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.8); }
}

/* Hero Title */
.fal-hero-title {
  font-family: 'Focal Medium', 'Focal', sans-serif !important;
  font-size: 56px !important;
  font-weight: 500 !important;
  line-height: 1 !important;
  margin: 16px 0 10px 0 !important;
  padding: 0 !important;
  letter-spacing: -1.12px !important;
  color: #242426 !important;
}

.dark .fal-hero-title {
  color: #fafafa !important;
}

.fal-hero-subtitle {
  font-family: 'Focal Medium', 'Focal', sans-serif;
  font-size: 20px;
  font-weight: 500;
  line-height: 1;
  letter-spacing: -0.4px;
  color: #242426;
  margin-bottom: 10px;
}

.dark .fal-hero-subtitle {
  color: #fafafa;
}

/* Hero Body Text */
.fal-hero-body {
  font-size: 16px;
  line-height: 1.4;
  margin-bottom: 1rem;
  color: #787881;
  letter-spacing: -0.32px;
}

.fal-hero-body strong {
  color: #242426;
}

.dark .fal-hero-body strong {
  color: #fafafa;
}

/* Hero Search Bar */
.fal-hero-search {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 360px;
  padding: 8px 10px;
  font-size: 13px;
  color: #9ca3af;
  background: white;
  border: 1px solid rgba(18, 18, 22, 0.1);
  cursor: pointer;
  text-align: left;
  transition: border-color 0.2s;
  margin-bottom: 1rem;
}

.fal-hero-search:hover {
  border-color: rgba(18, 18, 22, 0.2);
}

.dark .fal-hero-search {
  background: #1f2937;
  border-color: rgba(255, 255, 255, 0.1);
  color: #6b7280;
}

.fal-hero-search-icon {
  width: 14px;
  height: 14px;
  margin-right: 8px;
  flex-shrink: 0;
  color: #787881;
}

.fal-hero-search-text {
  flex: 1;
}

.fal-hero-mcp-link {
  display: flex;
  align-items: center;
  gap: 5px;
  margin-left: auto;
  padding: 3px 8px;
  font-size: 11px;
  font-weight: 600;
  color: #5718C0 !important;
  background: rgba(133, 83, 255, 0.08);
  text-decoration: none !important;
  white-space: nowrap;
  transition: background 0.2s;
}

.fal-hero-mcp-link:hover {
  background: rgba(133, 83, 255, 0.15);
}

.dark .fal-hero-mcp-link {
  color: #C0B1FF !important;
  background: rgba(133, 83, 255, 0.15);
}

.dark .fal-hero-mcp-link:hover {
  background: rgba(133, 83, 255, 0.25);
}

/* Stats Row */
.fal-stats-row {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-top: 1.5rem;
}

.fal-stat-item {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 8px;
  min-width: 99px;
}

.fal-stat-value {
  font-family: 'Focal Medium', 'Focal', sans-serif;
  font-size: 24px;
  font-weight: 500;
  line-height: 1;
  letter-spacing: -0.4px;
  color: #242426;
  cursor: default;
}

.dark .fal-stat-value {
  color: #fafafa;
}

.fal-stat-label {
  font-size: 14px;
  font-weight: 500;
  line-height: 1.4;
  letter-spacing: -0.28px;
  color: #787881;
}

/* Hero Layout */
.fal-hero-section {
  display: flex;
  gap: 2rem;
  align-items: flex-start;
  margin-bottom: 1.5rem;
}

.fal-hero-text {
  flex: 1;
  min-width: 0;
}

.fal-hero-image {
  flex: 1;
  min-width: 0;
}

/* Hero Image */
.fal-hero-image img {
  width: 100%;
  height: auto;
  display: block;
}

.fal-hero-img-dark {
  display: none !important;
}

.dark .fal-hero-img-light {
  display: none !important;
}

.dark .fal-hero-img-dark {
  display: block !important;
}

.dark .fal-hero-img-dark {
  display: block !important;
}

/* Feature Card Hover Enhancement */
.fal-feature-card {
  transition: all 0.3s ease !important;
  position: relative;
  overflow: hidden;
}

.fal-feature-card:hover {
  transform: translateY(-2px);
}

/* Responsive adjustments */
@media (max-width: 768px) {
  .fal-hero-section {
    flex-direction: column;
    align-items: center;
  }

  .fal-hero-text {
    width: 100%;
  }

  .fal-stats-row {
    gap: 1rem;
  }
  
  .fal-stat-value {
    font-size: 18px;
  }

  .fal-hero-image {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .fal-hero-image img {
    width: auto;
    max-width: 100%;
    max-height: 260px;
  }
}

/* ============================================
   FAL Platform Lifecycle Steps
   ============================================ */

.fal-lifecycle-step {
  position: relative;
  margin-bottom: 1rem;
  border-radius: 8px;
  overflow: hidden;
}

.fal-lifecycle-step.serverless {
  background: linear-gradient(135deg, rgba(51, 134, 254, 0.1) 0%, rgba(51, 134, 254, 0.02) 100%);
  border-left: 3px solid #3386FE;
}

.dark .fal-lifecycle-step.serverless {
  background: linear-gradient(135deg, rgba(51, 134, 254, 0.15) 0%, rgba(51, 134, 254, 0.05) 100%);
}

.fal-lifecycle-step.modelapis {
  background: linear-gradient(135deg, rgba(133, 83, 255, 0.1) 0%, rgba(133, 83, 255, 0.02) 100%);
  border-left: 3px solid #8553FF;
}

.dark .fal-lifecycle-step.modelapis {
  background: linear-gradient(135deg, rgba(133, 83, 255, 0.2) 0%, rgba(133, 83, 255, 0.05) 100%);
}

.fal-step-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.25rem 0.5rem;
}

.fal-step-number {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  font-size: 0.875rem;
  font-weight: 600;
  flex-shrink: 0;
}

.fal-lifecycle-step.serverless .fal-step-number {
  background: rgba(51, 134, 254, 0.15);
  color: #1841B5;
}

.dark .fal-lifecycle-step.serverless .fal-step-number {
  background: rgba(51, 134, 254, 0.25);
  color: #8EC8FF;
}

.fal-lifecycle-step.modelapis .fal-step-number {
  background: rgba(133, 83, 255, 0.15);
  color: #5718C0;
}

.dark .fal-lifecycle-step.modelapis .fal-step-number {
  background: rgba(133, 83, 255, 0.25);
  color: #C0B1FF;
}

.fal-step-title {
  font-size: 1.125rem;
  font-weight: 600;
  flex-grow: 1;
}

.fal-step-logo {
  height: 18px;
  opacity: 0.9;
}

.fal-lifecycle-step .fal-step-logo {
  filter: none;
}

.fal-step-content {
  padding: 0 1.25rem 1rem;
}

.fal-step-content p:first-child {
  margin-top: 0;
}

.fal-step-content ul {
  margin-bottom: 0;
}

/* Responsive */
@media (max-width: 640px) {
  .fal-step-header {
    flex-wrap: wrap;
  }
  
  .fal-step-logo {
    order: -1;
    width: 100%;
    margin-bottom: 0.5rem;
    height: 16px;
  }
}


