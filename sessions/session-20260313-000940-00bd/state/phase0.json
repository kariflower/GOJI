ll},{"index":8,"start_sec":58.0,"end_sec":63.5,"text":"今夜は何も言えない","language":null},{"index":9,"start_sec":64.0,"end_sec":70.0,"text":"二十年かけて 積み上げた塔が","language":null},{"index":10,"start_sec":70.0,"end_sec":75.0,"text":"砂の城みたいに 見え始めている","language":null},{"index":11,"start_sec":77.0,"end_sec":83.0,"text":"誰にも言えない 「分からない」という言葉","language":null},{"index":12,"start_sec":83.0,"end_sec":88.5,"text":"飲み込んで また朝が来る","language":null},{"index":13,"start_sec":93.0,"end_sec":98.0,"text":"若い彼らの背中が 遠く見える","language":null},{"index":14,"start_sec":98.0,"end_sec":104.0,"text":"同じ場所に立ってるはずなのに","language":null},{"index":15,"start_sec":105.0,"end_sec":111.0,"text":"追いつけないんじゃない 認めたくないだけ","language":null},{"index":16,"start_sec":111.0,"end_sec":117.5,"text":"プライドという名の 足枷を外せない","language":null},{"index":17,"start_sec":118.0,"end_sec":124.0,"text":"窓に映る顔が 知らない男に見える","language":null},{"index":18,"start_sec":124.0,"end_sec":129.0,"text":"あの頃の自信は どこへ行った","language":null},{"index":19,"start_sec":130.0,"end_sec":136.0,"text":"「まだやれる」と呟いても","language":null},{"index":20,"start_sec":136.0,"end_sec":142.0,"text":"声が震えてる","language":null},{"index":21,"start_sec":143.0,"end_sec":148.5,"text":"二十年かけて 覚えた全てが","language":null},{"index":22,"start_sec":149.0,"end_sec":154.5,"text":"指の隙間から 零れ落ちていく","language":null},{"index":23,"start_sec":155.0,"end_sec":160.5,"text":"強がりの鎧 脱ぎ捨てたら","language":null},{"index":24,"start_sec":161.0,"end_sec":167.0,"text":"何が残るんだろう","language":null},{"index":25,"start_sec":168.0,"end_sec":173.0,"text":"本当は...怖いんだ","language":null},{"index":26,"start_sec":174.0,"end_sec":179.5,"text":"変わらなきゃいけないと分かってる","language":null},{"index":27,"start_sec":181.0,"end_sec":185.5,"text":"でもこの手を離したら","language":null},{"index":28,"start_sec":186.0,"end_sec":193.0,"text":"俺は俺じゃなくなる気がして","language":null},{"index":29,"start_sec":196.0,"end_sec":201.5,"text":"二十年かけて 歩いてきた道","language":null},{"index":30,"start_sec":202.0,"end_sec":208.0,"text":"無駄じゃないと 信じていたい","language":null},{"index":31,"start_sec":209.0,"end_sec":214.5,"text":"明けない夜はない そう言うけれど","language":null},{"index":32,"start_sec":215.0,"end_sec":222.0,"text":"今夜だけは この暗闘に負けていい","language":null},{"index":33,"start_sec":225.0,"end_sec":231.0,"text":"蛍光灯が消える 静寂の中で","language":null},{"index":34,"start_sec":231.0,"end_sec":238.0,"text":"また明日 同じ椅子に座る","language":null}],"total_lines":34,"detected_language":"ja"},"phase0_diagnostics":{"audio_sections":[{"section_id":"sec-001","label":"intro","start_sec":0.0,"end_sec":12.84063492063492,"duration_sec":12.84063492063492,"confidence":0.6,"source":"librosa"},{"section_id":"sec-002","label":"verse1","start_sec":12.84063492063492,"end_sec":52.01269841269841,"duration_sec":39.172063492063494,"confidence":0.6,"source":"librosa"},{"section_id":"sec-003","label":"chorus1","start_sec":52.01269841269841,"end_sec":58.65360544217687,"duration_sec":6.640907029478456,"confidence":0.6,"source":"librosa"},{"section_id":"sec-004","label":"verse2","start_sec":58.65360544217687,"end_sec":81.33950113378685,"duration_sec":22.685895691609986,"confidence":0.6,"source":"librosa"},{"section_id":"sec-005","label":"chorus2","start_sec":81.33950113378685,"end_sec":91.60272108843537,"duration_sec":10.26321995464852,"confidence":0.6,"source":"librosa"},{"section_id":"sec-006","label":"verse3","start_sec":91.60272108843537,"end_sec":143.0813605442177,"duration_sec":51.478639455782314,"confidence":0.6,"source":"librosa"},{"section_id":"sec-007","label":"chorus3","start_sec":143.0813605442177,"end_sec":194.88507936507938,"duration_sec":51.80371882086169,"confidence":0.6,"source":"librosa"},{"section_id":"sec-008","label":"verse4","start_sec":194.88507936507938,"end_sec":209.02603174603175,"duration_sec":14.14095238095237,"confidence":0.6,"source":"librosa"},{"section_id":"sec-009","label":"chorus4","start_sec":209.02603174603175,"end_sec":216.59573696145125,"duration_sec":7.5697052154195035,"confidence":0.6,"source":"librosa"},{"section_id":"sec-010","label":"bridge","start_sec":216.59573696145125,"e