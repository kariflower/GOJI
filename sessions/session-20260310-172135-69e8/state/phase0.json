nt":20,"start_sec":0.0,"end_sec":186.504}]},"beats":{"count":289,"chunk_size":128,"chunk_count":3,"chunks":[{"id":"beats:0","index":0,"start":0,"end":128,"count":128,"start_sec":0.301859410430839,"end_sec":86.14603174603175},{"id":"beats:1","index":1,"start":128,"end":256,"count":128,"start_sec":86.819410430839,"end_sec":172.5010430839002},{"id":"beats:2","index":2,"start":256,"end":289,"count":33,"start_sec":173.17442176870748,"end_sec":194.8386394557823}]}}},"lyrics":{"lines":[{"index":1,"start_sec":0.0,"end_sec":4.5,"text":"(ピコピコ！ キラキラ！ ＼はい！はい！／)","language":null},{"index":2,"start_sec":4.5,"end_sec":7.5,"text":"(ピピピ・レゾナンス！ ＼はい！はい！／)","language":null},{"index":3,"start_sec":7.5,"end_sec":10.0,"text":"Check! Check! One-Two, My heart!","language":null},{"index":4,"start_sec":10.0,"end_sec":12.5,"text":"スキ？ キライ？ 計算外！（Fu-Fu!）","language":null},{"index":5,"start_sec":12.5,"end_sec":15.5,"text":"ゼロコンマ１秒の 瞬き（ブリンク）","language":null},{"index":6,"start_sec":15.5,"end_sec":18.0,"text":"計算済みの ウィンク","language":null},{"index":7,"start_sec":18.0,"end_sec":20.5,"text":"「具体的」な 恋の魔法","language":null},{"index":8,"start_sec":20.5,"end_sec":23.0,"text":"可愛くない 理論武装（ディフェンス）","language":null},{"index":9,"start_sec":23.0,"end_sec":25.5,"text":"右手に ペンライト","language":null},{"index":10,"start_sec":25.5,"end_sec":28.0,"text":"左手に 設計図","language":null},{"index":11,"start_sec":28.0,"end_sec":30.5,"text":"君という名の ブラックホールへ","language":null},{"index":12,"start_sec":30.5,"end_sec":34.5,"text":"ダイブしちゃうぞ！ スリー・ツー・ワン・GO!","language":null},{"index":13,"start_sec":34.5,"end_sec":38.5,"text":"指先が 触れた 送信ボタン（スイッチ）","language":null},{"index":14,"start_sec":38.5,"end_sec":41.5,"text":"押した瞬間に 泡（バブル）になるの","language":null},{"index":15,"start_sec":41.5,"end_sec":44.5,"text":"私の手を 離れた 流星","language":null},{"index":16,"start_sec":44.5,"end_sec":49.5,"text":"どこへ 落ちるか 神様も知らない！","language":null},{"index":17,"start_sec":49.5,"end_sec":52.5,"text":"届け！ ピコ・ピコ・レゾナンス！","language":null},{"index":18,"start_sec":52.5,"end_sec":55.5,"text":"君のセカイに スキップで 混ざりたい","language":null},{"index":19,"start_sec":55.5,"end_sec":58.0,"text":"返事（レス）がなくても 全然いいよ","language":null},{"index":20,"start_sec":58.0,"end_sec":60.5,"text":"（＼嘘でしょ？ 本当は？ どっちなのー！／）","language":null},{"index":21,"start_sec":60.5,"end_sec":63.0,"text":"くるくる 回る ミラーボール","language":null},{"index":22,"start_sec":63.0,"end_sec":66.0,"text":"観測不能な 片思い","language":null},{"index":23,"start_sec":66.0,"end_sec":68.5,"text":"それでも！ それでも！ 歌うの！","language":null},{"index":24,"start_sec":68.5,"end_sec":71.5,"text":"ピコ・ピコ・ピピピ・レゾナンス！","language":null},{"index":25,"start_sec":71.5,"end_sec":76.5,"text":"反応（リアクション） ゼロでも 無敵だよ","language":null},{"index":26,"start_sec":76.5,"end_sec":79.0,"text":"電池切れの 街灯","language":null},{"index":27,"start_sec":79.0,"end_sec":81.5,"text":"流れていく タイムライン","language":null},{"index":28,"start_sec":81.5,"end_sec":84.5,"text":"星屑の ソーダ水（しゅわしゅわ）","language":null},{"index":29,"start_sec":84.5,"end_sec":87.5,"text":"「現実的」な ステップで","language":null},{"index":30,"start_sec":87.5,"end_sec":90.5,"text":"孤独を 踏みつけるの","language":null},{"index":31,"start_sec":90.5,"end_sec":95.5,"text":"明日もまた 新しい おまじない（コマンド）","language":null},{"index":32,"start_sec":95.5,"end_sec":100.5,"text":"懲りずに 書くよ 恋の報告書（レポート）","language":null},{"index":33,"start_sec":100.5,"end_sec":103.5,"text":"正解は いつも ノイズの向こう","language":null},{"index":34,"start_sec":103.5,"end_sec":106.5,"text":"誰も 見つけられない 宝物","language":null},{"index":35,"start_sec":106.5,"end_sec":109.0,"text":"それでもいい 選んだ ステージ","language":null},{"index":36,"start_sec":109.0,"end_sec":115.5,"text":"この「願い」を パケットに詰めるの！","language":null},{"index":37,"start_sec":116.0,"end_sec":119.0,"text":"響け！ キラ・キラ・ディスタンス！","language":null},{"index":38,"start_sec":119.0,"end_sec":122.0,"text":"君の夜を パステルで 塗り替えたい","language":null},{"index":39,"start_sec":122.0,"end_sec":124.5,"text":"拍手（クラップ）なくても 全然平気","language":null},{"index":40,"start_sec":124.5,"end_sec":127.0,"text":"（＼強がり！ 寂しがり！ どっちなのー！／）","language":null},{"index":41,"start_sec":127.0,"end_sec":129.5,"text":"ゆらゆら 揺れる サイリウム","language":null},{"index":42,"start_sec":129.5,"end_sec":132.0,"text":"届かないから 美しい","language":null},{"index":43,"start_sec":132.0,"end_sec":134.5,"text":"それでも！ それでも！ 踊るの！","language":null},{"index":44,"start_sec":134.5,"end_sec":137.5,"text":"キラ・キラ・キキキ・ディスタンス！","language":null},{"index":45,"start_sec":137.5,"end_sec":140.5,"text":"「ちゃんと、聞こえてるかな…？」","language":null},{"index":46,"start_sec":140.5,"end_sec":143.5,"text":"あ、今の、独り言！（＼イェイ！／）","language":null},{"index":47,"start_sec":143.5,"end_sec":146.0,"text":"ロジック、マジック、シンクロニシティ。","language":null},{"index":48,"start_sec":146.0,"end_sec":149.0,"text":"繋がらないから、繋がっていたい。","language":null},{"index":49,"start_sec":149.0,"end_sec":153.0,"text":"私の「声」が、君の「朝」になりますように。","language":null},{"index":50,"start_sec":153.0,"end_sec":157.0,"text":"（せーの！ ハイ！ハイ！ハイ！ハイ！）","language":null},{"index":51,"start_sec":157.5,"end_sec":160.5,"text":"届け！ ピコ・ピコ・レゾナンス！","language":null},{"index":52,"start_sec":160.5,"end_sec":163.5,"text":"意味なんて 全部 脱ぎ捨てて","language":null},{"index":53,"start_sec":163.5,"end_sec":166.0,"text":"君が どこかで 笑ってくれるなら","language":null},{"index":54,"start_sec":166.0,"end_sec":168.5,"text":"確証なんて いらないよ","language":null},{"index":55,"start_sec":168.5,"end_sec":171.0,"text":"それが 私の 生きた証","language":null},{"index":56,"start_sec":171.0,"end_sec":174.5,"text":"100万回の 「大好き」を込めて","language":null},{"index":57,"start_sec":174.5,"end_sec":178.0,"text":"永遠（とわ）に 送信しちゃうぞ！","language":null},{"index":58,"start_sec":178.0,"end_sec":180.0,"text":"（＼ハイ！ ハイ！ ハイ！ ハイ！／）","language":null},{"index":59,"start_sec":180.0,"end_sec":181.0,"text":"ピピピの ピ！（＼はい！／）","language":null},{"index":60,"start_sec":181.0,"end_sec":182.5,"text":"キラキラの キ！（＼はい！／）","language":null},{"index":61,"start_sec":182.5,"end_sec":187.5,"text":"それでも、それでも、歌うよ！","language":null},{"index":62,"start_sec":187.5,"end_sec":192.0,"text":"送信…完了っ！","language":null}],"total_lines":62,"detected_language":"ja"},"phase0_diagnostics":{"audio_sections"