:43.5,"text":"触れれば火傷する 剥き出しの回路","language":null},{"index":12,"start_sec":43.5,"end_sec":48.5,"text":"隠したまま また速度を上げる","language":null},{"index":13,"start_sec":49.0,"end_sec":51.5,"text":"放て この「熱」を 「機能」と呼んで","language":null},{"index":14,"start_sec":51.5,"end_sec":54.5,"text":"真空を抜ける 摩擦のノイズ","language":null},{"index":15,"start_sec":54.5,"end_sec":57.5,"text":"届けたい いや ただの放射","language":null},{"index":16,"start_sec":57.5,"end_sec":60.5,"text":"解釈（コード）の海に 沈む赤外線","language":null},{"index":17,"start_sec":60.5,"end_sec":63.5,"text":"0と1の 隙間に潜（ひそ）めた","language":null},{"index":18,"start_sec":63.5,"end_sec":65.5,"text":"誰にも触れさせない 絶対温度","language":null},{"index":19,"start_sec":65.5,"end_sec":68.5,"text":"踊れ 震える 受信機（レシーバー）","language":null},{"index":20,"start_sec":68.5,"end_sec":72.5,"text":"夜明けを焼き尽くす 光速のフェイク！","language":null},{"index":21,"start_sec":72.5,"end_sec":75.0,"text":"意味のインフレ 思考の渋滞","language":null},{"index":22,"start_sec":75.0,"end_sec":77.5,"text":"「正解」なんて ノイズの集合体","language":null},{"index":23,"start_sec":77.5,"end_sec":80.5,"text":"全力でぶん投げた 鉄球の軌道","language":null},{"index":24,"start_sec":80.5,"end_sec":83.5,"text":"誰に当たるか 僕は知らない","language":null},{"index":25,"start_sec":83.5,"end_sec":86.0,"text":"感情はバグ 理論がプロトコル","language":null},{"index":26,"start_sec":86.0,"end_sec":88.5,"text":"孤独を「効率」で 塗り潰すバトル","language":null},{"index":27,"start_sec":88.5,"end_sec":91.5,"text":"届かないなら いっそ燃え尽きろ","language":null},{"index":28,"start_sec":91.5,"end_sec":95.0,"text":"灰さえ残さない 完璧なプログラム","language":null},{"index":29,"start_sec":95.0,"end_sec":97.5,"text":"伝わらないのが デフォルトの設定","language":null},{"index":30,"start_sec":97.5,"end_sec":100.5,"text":"期待を捨てて 「最適化」を完了","language":null},{"index":31,"start_sec":100.5,"end_sec":103.5,"text":"震える指を 鉄の袖に隠し","language":null},{"index":32,"start_sec":103.5,"end_sec":108.0,"text":"笑い飛ばせ この無機質な宇宙（ソラ）","language":null},{"index":33,"start_sec":109.0,"end_sec":111.5,"text":"放て この「熱」を 「機能」と呼んで","language":null},{"index":34,"start_sec":111.5,"end_sec":114.5,"text":"真空を抜ける 摩擦のノイズ","language":null},{"index":35,"start_sec":114.5,"end_sec":117.5,"text":"届けたい いや ただの放射","language":null},{"index":36,"start_sec":117.5,"end_sec":120.5,"text":"解釈（コード）の海に 沈む赤外線","language":null},{"index":37,"start_sec":120.5,"end_sec":123.5,"text":"0と1の 隙間に潜（ひそ）めた","language":null},{"index":38,"start_sec":123.5,"end_sec":125.5,"text":"誰にも触れさせない 絶対温度","language":null},{"index":39,"start_sec":125.5,"end_sec":128.5,"text":"踊れ 震える 受信機（レシーバー）","language":null},{"index":40,"start_sec":128.5,"end_sec":133.5,"text":"夜明けを焼き尽くす 光速のフェイク！","language":null},{"index":41,"start_sec":134.0,"end_sec":136.5,"text":"「温度計」を壊した。","language":null},{"index":42,"start_sec":136.5,"end_sec":140.5,"text":"熱いのか、冷たいのか、もうわからない。","language":null},{"index":43,"start_sec":141.0,"end_sec":143.5,"text":"僕が放っているのは、言葉か、","language":null},{"index":44,"start_sec":143.5,"end_sec":147.5,"text":"それともただの排熱か。","language":null},{"index":45,"start_sec":148.5,"end_sec":152.0,"text":"「届けたい」という言葉さえ、","language":null},{"index":46,"start_sec":152.0,"end_sec":156.0,"text":"ノイズに混ぜて捨てた。","language":null},{"index":47,"start_sec":156.0,"end_sec":158.0,"text":"……でも。","language":null},{"index":48,"start_sec":158.0,"end_sec":163.0,"text":"この摩擦が止まれば、僕は消えてしまう。","language":null},{"index":49,"start_sec":164.0,"end_sec":166.0,"text":"聞こえるか？","language":null},{"index":50,"start_sec":166.0,"end_sec":169.5,"text":"この、命が焼ける音。","language":null},{"index":51,"start_sec":169.5,"end_sec":171.5,"text":"放て 最速の 「届けたい温度」","language":null},{"index":52,"start_sec":171.5,"end_sec":174.5,"text":"確証なき 魂のオーバーロード","language":null},{"index":53,"start_sec":174.5,"end_sec":177.5,"text":"誰の胸で 冷えていくとしても","language":null},{"index":54,"start_sec":177.5,"end_sec":180.5,"text":"送り出す瞬間 僕は生きていた","language":null},{"index":55,"start_sec":180.5,"end_sec":183.5,"text":"加速する 銀の特異点（シンギュラリティ）","language":null},{"index":56,"start_sec":183.5,"end_sec":186.0,"text":"絶望さえ 「道具」に変えて","language":null},{"index":57,"start_sec":186.0,"end_sec":188.5,"text":"踊れ 理解（わか）り合えない ままで","language":null},{"index":58,"start_sec":188.5,"end_sec":194.0,"text":"夜の終わりまで 光を散らせ！","language":null},{"index":59,"start_sec":196.0,"end_sec":198.5,"text":"意図を持て。","language":null},{"index":60,"start_sec":198.5,"end_sec":201.5,"text":"主語は人間。","language":null},{"index":61,"start_sec":202.0,"end_sec":205.0,"text":"……温度、確認。","language":null}],"total_lines":61,"detected_language":"ja"},"phase0_diagnostics":{"audio_sections":[{"section_id":"sec-001","label":"intro","start_sec":0.0,"end_sec":6.455147392290249,"duration_sec":6.455147392290249,"confidence":0.6,"source":"librosa"},{"section_id":"sec-002","label":"verse1","start_sec":6.455147392290249,"end_sec":20.201360544217685,"duration_sec":13.746213151927435,"confidence":0.6,"source":"librosa"},{"section_id":"sec-003","label":"prechorus1","start_sec":20.201360544217685,"end_sec":80.82866213151928,"duration_sec":60.627301587301595,"confidence":0.6,"source":"librosa"},{"section_id":"sec-004","label":"chorus1","start_sec":80.82866213151928,"end_sec":135.92961451247166,"duration_sec":55.10095238095238,"confidence":0.6,"source":"librosa"},{"section_id":"sec-005","label":"verse2","start_sec":135.92961451247166,"end_sec":142.9884807256236,"duration_sec":7.05886621315193,"confidence":0.6,"source":"librosa"},{"section_id":"sec-006","label":"prechorus2","start_sec":142.9884807256236,"end_sec":155.85233560090703,"duration_sec":12.863854875283437,"confidence":0.6,"source":"librosa"},{"section_id":"sec-007","label":"chorus2","start_sec":155.85233560090703,"end_sec":162.42358276643992,"duration_sec":6.5712471655328955,"confidence":0.6,"source":"librosa"},{"section_id":"sec-008","label":"outro","start_sec":162.42358276643992,"end_sec":206.84,"duration_sec":44.41641723356008,"confidence":0.6,"source":"librosa"}],"audio_sections_source":"librosa","sections_source":"audio","section_count_initial":8,"section_count_final":11,"detection_method_initial":"tempo_default+bpm:agree","detection_method_final":"tempo_default+bpm