e","duration_sec","detection_method"],"arrays":{"sections":{"count":4,"chunk_size":16,"chunk_count":1,"chunks":[{"id":"sections:0","index":0,"start":0,"end":4,"count":4,"start_sec":0.0,"end_sec":242.999979}]},"emotional_arc":{"count":20,"chunk_size":32,"chunk_count":1,"chunks":[{"id":"emotional_arc:0","index":0,"start":0,"end":20,"count":20,"start_sec":0.0,"end_sec":242.999979}]},"beats":{"count":592,"chunk_size":128,"chunk_count":5,"chunks":[{"id":"beats:0","index":0,"start":0,"end":128,"count":128,"start_sec":2.941958,"end_sec":55.513206},{"id":"beats:1","index":1,"start":128,"end":256,"count":128,"start_sec":55.886105,"end_sec":105.651894},{"id":"beats:2","index":2,"start":256,"end":384,"count":128,"start_sec":106.03656,"end_sec":158.032745},{"id":"beats:3","index":3,"start":384,"end":512,"count":128,"start_sec":158.530746,"end_sec":211.38559},{"id":"beats:4","index":4,"start":512,"end":592,"count":80,"start_sec":211.769318,"end_sec":242.61586}]}}},"lyrics":{"lines":[{"index":1,"start_sec":13.0,"end_sec":18.0,"text":"蛍光灯が瞬く 深夜のオフィス","language":null},{"index":2,"start_sec":18.0,"end_sec":24.0,"text":"積み上げた書類の山が 影を落としてる","language":null},{"index":3,"start_sec":25.0,"end_sec":30.0,"text":"珈琲は冷めて 時計だけが進む","language":null},{"index":4,"start_sec":30.0,"end_sec":36.5,"text":"この椅子に座って もう何年経った","language":null},{"index":5,"start_sec":39.0,"end_sec":44.0,"text":"肩甲骨の奥が軋む","language":null},{"index":6,"start_sec":45.0,"end_sec":51.0,"text":"誰も知らない この部屋の静けさ","language":null},{"index":7,"start_sec":52.0,"end_sec":58.0,"text":"「大丈夫」と言い続けた唇が","language":null},{"index":8,"start_sec":58.0,"end_sec":63.5,"text":"今夜は何も言えない","language":null},{"index":9,"start_sec":64.0,"end_sec":70.0,"text":"二十年かけて 積み上げた塔が","language":null},{"index":10,"start_sec":70.0,"end_sec":75.0,"text":"砂の城みたいに 見え始めている","language":null},{"index":11,"start_sec":77.0,"end_sec":83.0,"text":"誰にも言えない 「分からない」という言葉","language":null},{"index":12,"start_sec":83.0,"end_sec":88.5,"text":"飲み込んで また朝が来る","language":null},{"index":13,"start_sec":93.0,"end_sec":98.0,"text":"若い彼らの背中が 遠く見える","language":null},{"index":14,"start_sec":98.0,"end_sec":104.0,"text":"同じ場所に立ってるはずなのに","language":null},{"index":15,"start_sec":105.0,"end_sec":111.0,"text":"追いつけないんじゃない 認めたくないだけ","language":null},{"index":16,"start_sec":111.0,"end_sec":117.5,"text":"プライドという名の 足枷を外せない","language":null},{"index":17,"start_sec":118.0,"end_sec":124.0,"text":"窓に映る顔が 知らない男に見える","language":null},{"index":18,"start_sec":124.0,"end_sec":129.0,"text":"あの頃の自信は どこへ行った","language":null},{"index":19,"start_sec":130.0,"end_sec":136.0,"text":"「まだやれる」と呟いても","language":null},{"index":20,"start_sec":136.0,"end_sec":142.0,"text":"声が震えてる","language":null},{"index":21,"start_sec":143.0,"end_sec":148.5,"text":"二十年かけて 覚えた全てが","language":null},{"index":22,"start_sec":149.0,"end_sec":154.5,"text":"指の隙間から 零れ落ちていく","language":null},{"index":23,"start_sec":155.0,"end_sec":160.5,"text":"強がりの鎧 脱ぎ捨てたら","language":null},{"index":24,"start_sec":161.0,"end_sec":167.0,"text":"何が残るんだろう","language":null},{"index":25,"start_sec":168.0,"end_sec":173.0,"text":"本当は...怖いんだ","language":null},{"index":26,"start_sec":174.0,"end_sec":179.5,"text":"変わらなきゃいけないと分かってる","language":null},{"index":27,"start_sec":181.0,"end_sec":185.5,"text":"でもこの手を離したら","language":null},{"index":28,"start_sec":186.0,"end_sec":193.0,"text":"俺は俺じゃなくなる気がして","language":null},{"index":29,"start_sec":196.0,"end_sec":201.5,"text":"二十年かけて 歩いてきた道","language":null},{"index":30,"start_sec":202.0,"end_sec":208.0,"text":"無駄じゃないと 信じていたい","language":null},{"index":31,"start_sec":209.0,"end_sec":214.5,"text":"明けない夜はない そう言うけれど","language":null},{"index":32,"start_sec":215.0,"end_sec":222.0,"text":"今夜だけは この暗闘に負けていい","language":null},{"index":33,"start_sec":225.0,"end_sec":231.0,"text":"蛍光灯が消える 静寂の中で","language":null},{"index":34,"start_sec":231.0,"end_sec":238.0,"text":"また明日 同じ椅子に座る","language":null}],"total_lines":34,"detected_language":"ja"},"phase0_diagnostics":{"audio_sections":[{"section_id":"section_0