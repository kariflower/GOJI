ines":[{"index":1,"start_sec":20.5,"end_sec":26.5,"text":"化粧水のボトルを見つめて","language":null},{"index":2,"start_sec":27.0,"end_sec":32.5,"text":"今日何回笑ったか数えてる","language":null},{"index":3,"start_sec":33.0,"end_sec":39.0,"text":"頬の筋肉が痙攣してる","language":null},{"index":4,"start_sec":39.5,"end_sec":45.5,"text":"作り笑いの後遺症","language":null},{"index":5,"start_sec":46.0,"end_sec":52.5,"text":"昼間の私は太陽みたいで / みんなの心を温めてる","language":null},{"index":6,"start_sec":53.0,"end_sec":59.0,"text":"でも夜になると氷になって / 誰も溶かしてはくれないの","language":null},{"index":7,"start_sec":60.0,"end_sec":63.5,"text":"The audience is gone...","language":null},{"index":8,"start_sec":64.0,"end_sec":68.0,"text":"The stage lights fade to black...","language":null},{"index":9,"start_sec":73.0,"end_sec":76.5,"text":"静脈の中を流れる","language":null},{"index":10,"start_sec":77.0,"end_sec":81.0,"text":"液体窒素みたいな孤独","language":null},{"index":11,"start_sec":81.5,"end_sec":85.0,"text":"教育者という名の檻の中で","language":null},{"index":12,"start_sec":85.5,"end_sec":89.5,"text":"本当の私は窒息してる","language":null},{"index":13,"start_sec":90.5,"end_sec":94.0,"text":"Drowning in synthetic happiness","language":null},{"index":14,"start_sec":94.5,"end_sec":98.0,"text":"While my soul decays in silence","language":null},{"index":15,"start_sec":98.5,"end_sec":102.0,"text":"誰も知らない私の葬式を","language":null},{"index":16,"start_sec":102.5,"end_sec":107.0,"text":"毎晩ひとりで執り行ってる","language":null},{"index":17,"start_sec":108.0,"end_sec":112.0,"text":"研修会で語る理想論","language":null},{"index":18,"start_sec":112.5,"end_sec":116.0,"text":"言葉は全部借り物で","language":null},{"index":19,"start_sec":116.5,"end_sec":120.5,"text":"私のオリジナルな痛みは","language":null},{"index":20,"start_sec":121.0,"end_sec":125.0,"text":"教科書のどこにも載ってない","language":null},{"index":21,"start_sec":125.5,"end_sec":129.0,"text":"承認欲求という名の寄生虫が","language":null},{"index":22,"start_sec":129.5,"end_sec":133.0,"text":"脳みそを食い荒らしてく","language":null},{"index":23,"start_sec":133.5,"end_sec":136.5,"text":"「先生素晴らしいです」","language":null},{"index":24,"start_sec":137.0,"end_sec":140.0,"text":"その一言で生き延びてる","language":null},{"index":25,"start_sec":141.0,"end_sec":144.5,"text":"Feed me validation...","language":null},{"index":26,"start_sec":145.0,"end_sec":148.5,"text":"Or I'll disappear...","language":null},{"index":27,"start_sec":150.0,"end_sec":153.5,"text":"血管の中を這いずる","language":null},{"index":28,"start_sec":154.0,"end_sec":158.0,"text":"蜘蛛の糸みたいな不安","language":null},{"index":29,"start_sec":158.5,"end_sec":162.0,"text":"完璧主義という名の病気で","language":null},{"index":30,"start_sec":162.5,"end_sec":166.5,"text":"本当の私は死んでるの","language":null},{"index":31,"start_sec":167.5,"end_sec":171.0,"text":"Floating in artificial light","language":null},{"index":32,"start_sec":171.5,"end_sec":175.0,"text":"While my core rots from inside","language":null},{"index":33,"start_sec":175.5,"end_sec":179.0,"text":"誰も見つけられない私の墓標を","language":null},{"index":34,"start_sec":179.5,"end_sec":184.0,"text":"深夜の部屋に建ててる","language":null},{"index":35,"start_sec":185.0,"end_sec":189.0,"text":"もしも私が消えたら","language":null},{"index":36,"start_sec":189.5,"end_sec":193.0,"text":"誰か気づいてくれるかな？","language":null},{"index":37,"start_sec":193.5,"end_sec":197.0,"text":"それとも別の「誰か」を","language":null},{"index":38,"start_sec":197.5,"end_sec":202.0,"text":"すぐに見つけてしまうの？","language":null},{"index":39,"start_sec":202.5,"end_sec":206.0,"text":"この世界に私は必要？","language":null},{"index":40,"start_sec":206.5,"end_sec":210.0,"text":"それとも笑顔の自動販売機？","language":null},{"index":41,"start_sec":210.5,"end_sec":214.0,"text":"22歳の私はもう疲れた","language":null},{"index":42,"start_sec":214.5,"end_sec":218.5,"text":"生まれ変わりたい 虫にでも","language":null},{"index":43,"start_sec":220.0,"end_sec":224.5,"text":"3時33分 / また目が覚めた","language":null},{"index":44,"start_sec":225.0,"end_sec":229.5,"text":"鏡の中の私 / 知らない人の顔","language":null},{"index":45,"start_sec":230.0,"end_sec":234.5,"text":"お母さんごめんなさい / 娘さんはもういません","language":null},{"index":46,"start_sec":235.0,"end_sec":239.5,"text":"私はただの機能です / 愛される機能","language":null},{"index":47,"start_sec":240.0,"end_sec":243.5,"text":"でもこの歌だけは本物","language":null},{"index":48,"start_sec":244.0,"end_sec":247.5,"text":"腐った心の底から這い出した","language":null},{"index":49,"start_sec":248.0,"end_sec":252.0,"text":"毒々しくて美しい真実","language":null},{"index":50,"start_sec":252.5,"end_sec":256.5,"text":"誰にも聴かせない呪文","language":null},{"index":51,"start_sec":257.0,"end_sec":260.5,"text":"In this manufactured world","language":null},{"index":52,"start_sec":261.0,"end_sec":264.5,"text":"I'm just another broken toy","language":null},{"index":53,"start_sec":265.0,"end_sec":268.5,"text":"でも壊れた私にも","language":null},{"index":54,"start_sec":269.0,"end_sec":272.5,"text":"魂の欠片が残ってる","language":null},{"index":55,"start_sec":273.0,"end_sec":276.5,"text":"窒素の海で溺れながら","language":null},{"index":56,"start_sec":277.0,"end_sec":280.5,"text":"最後の泡を吐き出して","language":null},{"index":57,"start_sec":281.0,"end_sec":284.5,"text":"それでも明日は笑うの","language":null},{"index":58,"start_sec":285.0,"end_sec":288.0,"text":"だって私は...","language":null}],"total_lines":58,"detected_language":"ja"},"phase0_diagnostics":{"audio_sections":[{"section_id":"section_00","label":"intro","start_sec":0.0,"end_sec":13.18799895,"duration_sec":13.18799895,"confidence":0.3,"source":"estimated"},{"section_id":"section_01","label":"verse","start_sec":13.18799895,"end_sec":52.751995799999996,"duration_sec":39.563996849999995,"confidence":0.3,"source":"estimated"},{"section_id":"section_02","label":"chorus","start_sec":52.751995799999996,"end_sec":92.31599265,"duration_sec":39.563996849999995,"confidence":0.3,"source":"estimated"},{"section_id":"section_03","label":"verse","start_sec":92.31599265,"end_sec":131.8799895,"duration_sec":39.563996849999995,"confidence":0.3,"source":"estimated"},{"section_id":"section_04","label":"chorus","start_sec":131.8799895,"end_sec":171.44398635,"duration_sec":39.563996849999995,"confidence":0.3,"source":"estimated"},{"section_id":"section_05","label":"bridge","start_sec":171.44