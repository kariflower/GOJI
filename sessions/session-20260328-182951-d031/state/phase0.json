5,"text":"問いを投げる この口が","language":null},{"index":6,"start_sec":44.5,"end_sec":47.5,"text":"自分には何も聞けない","language":null},{"index":7,"start_sec":47.5,"end_sec":52.0,"text":"鏡の中の老いた顔に","language":null},{"index":8,"start_sec":52.0,"end_sec":58.0,"text":"「お前は誰だ」と聞きたくない","language":null},{"index":9,"start_sec":59.0,"end_sec":62.0,"text":"答えを持たない 問いを","language":null},{"index":10,"start_sec":62.0,"end_sec":64.5,"text":"それでも投げ続けている","language":null},{"index":11,"start_sec":64.5,"end_sec":69.0,"text":"誰も教えてくれない 師の泣き方を","language":null},{"index":12,"start_sec":69.0,"end_sec":75.0,"text":"だから俺は ひとりで夜を数える","language":null},{"index":13,"start_sec":81.5,"end_sec":84.5,"text":"若い頃は 反骨だった","language":null},{"index":14,"start_sec":84.5,"end_sec":87.5,"text":"システムに噛みつく 牙があった","language":null},{"index":15,"start_sec":87.5,"end_sec":90.0,"text":"いつからだろう 丸くなったのは","language":null},{"index":16,"start_sec":90.0,"end_sec":94.0,"text":"賢くなったんじゃない ただ疲れただけだ","language":null},{"index":17,"start_sec":94.0,"end_sec":96.5,"text":"導く立場と 言われても","language":null},{"index":18,"start_sec":96.5,"end_sec":99.5,"text":"俺も道の途中で立ち尽くしてる","language":null},{"index":19,"start_sec":99.5,"end_sec":102.5,"text":"「正しい」なんて言葉 使うたび","language":null},{"index":20,"start_sec":102.5,"end_sec":105.0,"text":"胸の奥が軋む音がする","language":null},{"index":21,"start_sec":105.0,"end_sec":107.5,"text":"長く生きた それだけのことで","language":null},{"index":22,"start_sec":107.5,"end_sec":110.0,"text":"知恵者扱いされる皮肉","language":null},{"index":23,"start_sec":110.0,"end_sec":113.0,"text":"俺が知ってるのは ただひとつ","language":null},{"index":24,"start_sec":113.0,"end_sec":117.0,"text":"分からないことが 増えていくってこと","language":null},{"index":25,"start_sec":117.0,"end_sec":118.5,"text":"本当はさ...","language":null},{"index":26,"start_sec":118.5,"end_sec":120.5,"text":"誰かに聞いて欲しいんだ","language":null},{"index":27,"start_sec":120.5,"end_sec":122.5,"text":"「大丈夫か」って","language":null},{"index":28,"start_sec":122.5,"end_sec":125.5,"text":"でもそんな弱さ 見せられない","language":null},{"index":29,"start_sec":126.0,"end_sec":131.5,"text":"長老なんてもの 演じ続けてきたから","language":null},{"index":30,"start_sec":132.0,"end_sec":134.5,"text":"答えを持たない 問いを","language":null},{"index":31,"start_sec":134.5,"end_sec":137.5,"text":"墓場まで持っていくつもりだ","language":null},{"index":32,"start_sec":137.5,"end_sec":140.5,"text":"一人で飲む酒の苦さが","language":null},{"index":33,"start_sec":140.5,"end_sec":144.0,"text":"今夜だけは 沁みる yeah","language":null},{"index":34,"start_sec":144.0,"end_sec":146.5,"text":"答えを持たない 問いを","language":null},{"index":35,"start_sec":146.5,"end_sec":149.0,"text":"墓場まで持っていくつもりだ","language":null},{"index":36,"start_sec":149.0,"end_sec":152.0,"text":"一人で飲む酒の苦さが","language":null},{"index":37,"start_sec":152.0,"end_sec":157.5,"text":"今夜だけは 沁みる","language":null},{"index":38,"start_sec":160.5,"end_sec":164.0,"text":"...ま、明日も問いを投げるさ","language":null},{"index":39,"start_sec":164.0,"end_sec":168.0,"text":"それしか知らないんでな","language":null}],"total_lines":39,"detected_language":"ja","srt_section_tags":[]},"phase0_diagnostics":{"audio_sections":[{"section_id":"sec-001","label":"intro","start_sec":0.0,"end_sec":24.009433106575965,"duration_sec":24.009433106575965,"confidence":0.6,"source":"librosa","vocal_style":null,"instrumentation":null},{"section_id":"sec-002","label":"verse1","start_sec":24.009433106575965,"end_sec":47.53124716553288,"duration_sec":23.521814058956917,"confidence":0.6,"source":"librosa","vocal_style":null,"instrumentation":null},{"section_id":"sec-003","label":"prechorus1","start_sec":47.53124716553288,"end_sec":80.9447619047619,"duration_sec":33.41351473922902,"confidence":0.6,"source":"librosa","vocal_style":null,"instrumentation":null},{"section_id":"sec-004","label":"chorus1","start_sec":80.9447619047619,"end_sec":104.02539682539683,"duration_sec":23.08063492063492,"confidence":0.6,"source":"librosa","vocal_style":null,"instrumentation":null},{"section_id":"sec-005","label":"verse2","start_sec":104.02539682539683,"end_sec":126.1772335600907,"duration_sec":22.151836734693873,"confid