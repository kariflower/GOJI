":null},{"index":28,"start_sec":108.6,"end_sec":111.8,"text":"本当のことを言うのは僕だけ","language":null},{"index":29,"start_sec":112.1,"end_sec":115.3,"text":"透明な檻の中で踊る人形","language":null},{"index":30,"start_sec":115.6,"end_sec":118.8,"text":"誰の操り糸を切ればいいの？","language":null},{"index":31,"start_sec":119.1,"end_sec":122.3,"text":"14歳の血が沸騰してる","language":null},{"index":32,"start_sec":122.6,"end_sec":125.8,"text":"この偽物の皮膚を剥がしたい","language":null},{"index":33,"start_sec":126.1,"end_sec":129.3,"text":"Tear apart this manufactured soul","language":null},{"index":34,"start_sec":129.6,"end_sec":132.8,"text":"Find the beating heart underneath","language":null},{"index":35,"start_sec":133.1,"end_sec":136.3,"text":"本当の僕はもっと醜くて","language":null},{"index":36,"start_sec":136.6,"end_sec":139.8,"text":"もっと美しいはずなのに","language":null},{"index":37,"start_sec":140.1,"end_sec":143.3,"text":"お母さん、ごめん","language":null},{"index":38,"start_sec":143.6,"end_sec":146.8,"text":"僕は君が望む息子になれない","language":null},{"index":39,"start_sec":147.1,"end_sec":150.3,"text":"先生、ごめん","language":null},{"index":40,"start_sec":150.6,"end_sec":153.8,"text":"僕は型にはまる生徒になれない","language":null},{"index":41,"start_sec":154.1,"end_sec":157.3,"text":"でもそれでも生きていたい","language":null},{"index":42,"start_sec":157.6,"end_sec":160.8,"text":"傷だらけでも本物でいたい","language":null},{"index":43,"start_sec":161.1,"end_sec":164.3,"text":"この狂った世界で","language":null},{"index":44,"start_sec":164.6,"end_sec":167.8,"text":"一人ぼっちでも","language":null},{"index":45,"start_sec":168.1,"end_sec":171.3,"text":"透明な檻を蹴り破る音が","language":null},{"index":46,"start_sec":171.6,"end_sec":174.8,"text":"今夜の僕のテーマソング","language":null},{"index":47,"start_sec":175.1,"end_sec":178.3,"text":"14歳の革命はここから始まる","language":null},{"index":48,"start_sec":178.6,"end_sec":181.8,"text":"誰も知らない小さな戦争","language":null},{"index":49,"start_sec":182.1,"end_sec":185.3,"text":"Break apart this plastic world","language":null},{"index":50,"start_sec":185.6,"end_sec":188.8,"text":"Find the truth beneath the