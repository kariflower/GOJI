":{"lines":[{"index":1,"start_sec":1.0,"end_sec":2.5,"text":"Packin' up","language":null},{"index":2,"start_sec":2.5,"end_sec":4.5,"text":"Shut the transmitter off","language":null},{"index":3,"start_sec":4.5,"end_sec":7.0,"text":"Takin' my Rosetta Stone","language":null},{"index":4,"start_sec":7.0,"end_sec":9.5,"text":"Headin' for the only part of here","language":null},{"index":5,"start_sec":9.5,"end_sec":11.5,"text":"Solo","language":null},{"index":6,"start_sec":16.5,"end_sec":20.0,"text":"As I'm drivin' and the city's dyin'","language":null},{"index":7,"start_sec":20.0,"end_sec":23.0,"text":"There is one thing I'm allowin'","language":null},{"index":8,"start_sec":23.0,"end_sec":28.0,"text":"Hopin' that your eyes and the mist'll mix again","language":null},{"index":9,"start_sec":28.5,"end_sec":32.5,"text":"So packed up in a Wheeler car","language":null},{"index":10,"start_sec":32.5,"end_sec":38.5,"text":"Travelin' northbound to the stars","language":null},{"index":11,"start_sec":38.5,"end_sec":44.0,"text":"Flyin' on Nimbus floors","language":null},{"index":12,"start_sec":44.0,"end_sec":46.5,"text":"Meetin' where the fire be warm","language":null},{"index":13,"start_sec":46.5,"end_sec":48.0,"text":"Hold on","language":null},{"index":14,"start_sec":48.0,"end_sec":50.0,"text":"Here we are","language":null},{"index":15,"start_sec":50.5,"end_sec":54.0,"text":"For whatever reason I'm believin'","language":null},{"index":16,"start_sec":54.0,"end_sec":57.0,"text":"We're from the same dimension","language":null},{"index":17,"start_sec":57.0,"end_sec":60.0,"text":"On a day while funnin'","language":null},{"index":18,"start_sec":60.0,"end_sec":62.0,"text":"Fancy parts of chords ended","language":null},{"index":19,"start_sec":62.5,"end_sec":66.0,"text":"It's broadcasted on the ritual","language":null},{"index":20,"start_sec":66.0,"end_sec":69.0,"text":"That your eyes ain't never close","language":null},{"index":21,"start_sec":69.0,"end_sec":73.0,"text":"So let me see them as we lose control","language":null},{"index":22,"start_sec":73.0,"end_sec":77.5,"text":"Like marbles","language":null},{"index":23,"start_sec":78.0,"end_sec":80.0,"text":"I can","language":null},{"index":24,"start_sec":80.0,"end_sec":81.5,"text":"Too?","language":null},{"index":25,"start_sec":81.5,"end_sec":83.5,"text":"Not yet","language":null},{"index":26,"start_sec":83.5,"end_sec":85.5,"text":"But soon","language":null},{"index":27,"start_sec":85.5,"end_sec":88.5,"text":"When my Eclipse attend","language":null},{"index":28,"start_sec":88.5,"end_sec":91.5,"text":"You could fuel me with your oxygen","language":null},{"index":29,"start_sec":91.5,"end_sec":94.5,"text":"And we'd be at peace","language":null}],"total_lines":29,"detected_language":"en","srt_section_tags":[{"raw":"Intro","section_name":"Intro","vocal_style":null,"instrumentation":null,"time_sec":0.0},{"raw":"Verse","section_name":"Verse","vocal_style":null,"instrumentation":null,"time_sec":0.5},{"raw":"Interlude","section_name":"Interlude","vocal_style":null,"instrumentation":null,"time_sec":11.5},{"raw":"Verse 2","section_name":"Verse 2","vocal_style":null,"instrumentation":null,"time_sec":16.0},{"raw":"Chorus","section_name":"Chorus","vocal_style":null,"instrumentation":null,"time_sec":28.0},{"raw":"Verse 3","section_name":"Verse 3","vocal_style":null,"instrumentation":null,"time_sec":50.0},{"raw":"Verse 4","section_name":"Verse 4","vocal_style":null,"instrumentation":null,"time_sec":62.0},{"raw":"Bridge","section_name":"Bridge","vocal_style":null,"instrumentation":null,"time_sec":77.5},{"raw":"Outro","section_name":"Outro","vocal_style":null,"instrumentation":null,"time_sec":94.5}]},"phase0_diagnostics":{"audio_sections":[{"section_id":"sec-001","label":"intro","start_sec":0.0,"end_sec":28.421224489795918,"duration_sec":28.421224489795918,"confidence":0.6,"source":"librosa","vocal_style":null,"instrumentation":null},{"section_id":"sec-002","label":"verse1","start_sec":28.421224489795918,"end_sec":75.74